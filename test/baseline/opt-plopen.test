; Test --plopen: unrealized P&L for open positions at today's market price.
; Unlike --gain (which uses --revalued), --plopen does not insert synthetic
; revaluation postings; it simply shows market(amount, today) - cost.

P 2024/01/01 AAPL $150.00
P 2024/06/01 AAPL $200.00

2024/01/01 Buy AAPL
    Assets:Brokerage    10 AAPL @ $150.00
    Assets:Cash

test bal --plopen --now 2024/06/01 Assets:Brokerage
             $500.00  Assets:Brokerage
end test

test reg --plopen --now 2024/06/01 Assets:Brokerage
24-Jan-01 Buy AAPL              Assets:Brokerage            $500.00      $500.00
end test
