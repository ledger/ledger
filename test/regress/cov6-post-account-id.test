; Test post account_id with multiple postings to same account
; Covers post.cc line 566 (account_id incrementing past first posting)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --format '%(account_id)\n' Expenses
1
2
end test
