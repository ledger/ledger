; Test token parsing for match operator =~ (lines 362-368 of token.cc)
; and not-equal operator != (lines 290-296 of token.cc)
; and less-equal operator <= (lines 382-387 of token.cc)
; and greater-equal operator >= (lines 394-398 of token.cc)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --limit "amount != {\$10} and amount <= {\$20} and amount >= {\$20}"
24-Jan-02 Test2                 Expenses:Food                $20.00       $20.00
end test
