; Test token parsing for match operator =~
; not-equal operator !=
; less-equal operator <=
; greater-equal operator >=

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --limit "amount != {\$10} and amount <= {\$20} and amount >= {\$20}"
24-Jan-02 Test2                 Expenses:Food                $20.00       $20.00
end test
