; Coverage test for filters.cc line 350
; handle_value sets POST_MUST_BALANCE for auto-virtualized accounts
; that contain only balanced-virtual postings

2024/01/01 Test
    Expenses:Food    $10.00
    [Budget:Food]    $10.00
    Assets:Cash     $-10.00
    [Budget:Cash]   $-10.00

2024/01/02 Test
    Expenses:Food    $20.00
    [Budget:Food]    $20.00
    Assets:Cash     $-20.00
    [Budget:Cash]   $-20.00

test reg --subtotal
24-Jan-01 - 24-Jan-02           Assets:Cash                 $-30.00      $-30.00
                                [Budget:Cash]               $-30.00      $-60.00
                                [Budget:Food]                $30.00      $-30.00
                                Expenses:Food                $30.00            0
end test
