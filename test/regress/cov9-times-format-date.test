2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --date-format "%Y/%m/%d"
2024/01/01 Test                 Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
