; Coverage test for format.cc
; Test expression element with min_width set. Using %N(expr) sets a minimum
; width for the expression output, triggering value.print() with width
; justification instead of simple to_string().

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format '%20(account)\n'
       Expenses:Food
end test
