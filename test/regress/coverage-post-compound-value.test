; Coverage test for post.cc
; Tests compound_value paths in get_amount, get_commodity, and
; get_commodity_is_primary when POST_EXT_COMPOUND is set.
; The --subtotal flag causes subtotal_posts to set compound_value.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/15 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --subtotal --format='%(amount) %(commodity(amount)) %(primary) %(cost) %(account)\n'
$-30.00 $ false $-30.00 Assets:Cash
$30.00 $ false $30.00 Expenses:Food
end test
