; Coverage for report.cc lines 1058-1076: type conversion functions
; fn_to_amount, fn_to_balance, fn_to_string, fn_to_mask, fn_to_sequence
; Exercises these functions via format expressions in register reports

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

; fn_to_amount (line 1058-1060)
test reg --format '%(to_amount(amount))\n' Expenses
$10.00
end test

; fn_to_balance (line 1062-1064)
test reg --format '%(to_balance(amount))\n' Expenses
$10.00
end test

; fn_to_string (line 1066-1068)
test reg --format '%(to_string(account))\n' Expenses
Expenses:Food
end test

; fn_to_mask (line 1070-1072)
test reg --format '%(to_mask("Food"))\n' Expenses
Food
end test
