; Test FIFO auto-matching for xact.cc via --lot-matching fifo
; When selling unannotated shares, FIFO should auto-match against lots

2024/01/01 Buy Lot 1
    Assets:Broker          10 AAPL {$100.00} [2024/01/01]
    Assets:Cash

2024/02/01 Buy Lot 2
    Assets:Broker           5 AAPL {$150.00} [2024/02/01]
    Assets:Cash

2024/03/01 Sell unannotated (FIFO auto-match)
    Assets:Broker          -8 AAPL @ $200.00
    Income:Gains

; After FIFO auto-matching: sold 8 from Lot (oldest first)
; Remaining: 2 from Lot ($100) + 5 from Lot ($150)
test bal Assets:Broker --lot-matching fifo --lot-prices --lot-dates
2 AAPL {$100} [2024/01/01]
5 AAPL {$150} [2024/02/01]  Assets:Broker
end test
