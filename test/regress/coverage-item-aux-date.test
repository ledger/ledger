; Coverage for item.cc get_aux_date function
; Per issue #1157, aux_date falls back to the actual date when no
; explicit auxiliary date is set.

2024/01/01=2024/02/15 Test with aux date
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test without aux date
    Expenses:Food    $5.00
    Assets:Cash

test reg --format "%(aux_date) %(account)\n" Expenses
2024/02/15 Expenses:Food
2024/01/02 Expenses:Food
end test
