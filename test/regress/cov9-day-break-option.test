; Test --day-break option parsing in session.cc
; Note: --day-break only affects timeclock entries; with regular
; transactions it is accepted but has no effect on output

2024/01/15 Test1
    Expenses:Food    $30.00
    Assets:Cash

2024/01/15 Test2
    Expenses:Food    $20.00
    Assets:Cash

2024/01/16 Test3
    Expenses:Food    $10.00
    Assets:Cash

test reg --day-break --limit "account =~ /Expenses/"
24-Jan-15 Test1                 Expenses:Food                $30.00       $30.00
24-Jan-15 Test2                 Expenses:Food                $20.00       $50.00
24-Jan-16 Test3                 Expenses:Food                $10.00       $60.00
end test
