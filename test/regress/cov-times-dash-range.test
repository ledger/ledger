; Coverage test for times.cc
; Exercise dash operator in period parsing (date range)
; Covers handle_dash_operator

2024/01/01 January
    Expenses:Food            $10.00
    Assets:Cash

2024/06/01 June
    Expenses:Food            $20.00
    Assets:Cash

2024/12/01 December
    Expenses:Food            $30.00
    Assets:Cash

; "2024/01/01 - 2024/06/30" exercises TOK_DASH -> handle_dash_operator
test reg Expenses --period "2024/01/01 - 2024/06/30"
24-Jan-01 January               Expenses:Food                $10.00       $10.00
24-Jun-01 June                  Expenses:Food                $20.00       $30.00
end test
