; Coverage test for src/query.cc: query parser with AND, OR, NOT operators
; Tests complex query expressions that exercise the query parser edge cases.

2024/01/01 Grocery Store
    Expenses:Food:Groceries    $50.00
    Assets:Checking

2024/01/02 Restaurant
    Expenses:Food:Dining       $30.00
    Assets:Cash

2024/01/03 Electric Bill
    Expenses:Utilities         $100.00
    Assets:Checking

2024/01/04 Gas Station
    Expenses:Auto:Gas          $40.00
    Assets:Cash

test reg Expenses and not Food
24-Jan-03 Electric Bill         Expenses:Utilities          $100.00      $100.00
24-Jan-04 Gas Station           Expenses:Auto:Gas            $40.00      $140.00
end test

test reg Food or Auto
24-Jan-01 Grocery Store         Expense:Food:Groceries       $50.00       $50.00
24-Jan-02 Restaurant            Expenses:Food:Dining         $30.00       $80.00
24-Jan-04 Gas Station           Expenses:Auto:Gas            $40.00      $120.00
end test

test bal not Assets
             $220.00  Expenses
              $40.00    Auto:Gas
              $80.00    Food
              $30.00      Dining
              $50.00      Groceries
             $100.00    Utilities
--------------------
             $220.00
end test
