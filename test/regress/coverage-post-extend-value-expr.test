; Test posting with Value tag present in journal data
; Targets: post.cc (extend_post with Value tag)
; Note: bal output shows raw commodity quantity; the Value tag does not
; visibly affect the output of this particular command

2024/01/15 * Buy Stock
    ; Value: market(amount, date, exchange)
    Assets:Investments         10 AAPL @ $150.00
    Assets:Checking

test bal Assets:Investments --columns 80
             10 AAPL  Assets:Investments
end test
