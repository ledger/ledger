; Coverage for report.cc break statements in FUNCTION lookup:
; Line (case 'j'), (case 'l'), (case 'o')
; Line (case 'q'), (case 'r'), (case 's')
; When a function name starts with the right letter but does not match
; any known function, the break fires and control falls through to the
; option lookup

2024/01/01 Test
    Expenses:Food  $10.00
    Assets:Cash

; 'lot_dates' starts with 'l', not lifo_lots -> break at 1553 -> option lookup
test eval 'lot_dates'
0
end test

; 'only_' starts with 'o', not options -> break at 1574 -> option lookup
test eval 'only_'
end test

; 'quarterly' starts with 'q', not quoted/quoted_rfc/quantity -> break 1592 -> option
test eval 'quarterly'
0
end test

; 'related' starts with 'r', not rounded/red/round/roundto -> break 1603 -> option
test eval 'related'
0
end test

; 'subtotal' starts with 's', not scrub/strip/should_bold/set_commodity_price -> break 1614
test eval 'subtotal'
0
end test
