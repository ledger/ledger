; Test the "period" command which exercises show_period_tokens and dump
; Exercises: show_period_tokens
; token_t::dump
; token_t::to_string
; date_interval_t::dump
; date_interval_t::stabilize
; date_interval_t::resolve_end
; date_interval_t::operator++
; date_duration_t::find_nearest
; date_duration_t operator<<

2024/01/15 Payee A
    Expenses:Food    $50.00
    Assets:Checking

test period --now 2024/06/15 "monthly from 2024/01 to 2024/05"
--- Period expression tokens ---
TOK_MONTHLY: monthly
TOK_SINCE: since
TOK_DATE:  year 2024 month Jan
TOK_UNTIL: until
TOK_DATE:  year 2024 month May
END_REACHED: <EOF>

--- Before stabilization ---
   range: from year 2024 month Jan to year 2024 month May
duration: 1 month

--- After stabilization ---
   range: from year 2024 month Jan to year 2024 month May
   start: 24-Jan-01
  finish: 24-May-01
duration: 1 month

--- Sample dates in range (max. 20) ---
 1: 24-Jan-01 -- 24-Jan-31
 2: 24-Feb-01 -- 24-Feb-29
 3: 24-Mar-01 -- 24-Mar-31
 4: 24-Apr-01 -- 24-Apr-30
end test
