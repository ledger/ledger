; Coverage for times.cc lines 1561-1612: date_interval_t::dump
; The "period" command exercises interval stabilization and sample date output
; "today" hits the no-duration path (line 1608)

2024/01/15 Test
    Expenses:Food    $10.00
    Assets:Cash

test --now 2024/01/15 period "today"
--- Period expression tokens ---
TOK_TODAY: today
END_REACHED: <EOF>

--- Before stabilization ---
   range: in year 2024 month Jan day 15

--- After stabilization ---
   range: in year 2024 month Jan day 15
   start: 24-Jan-15
  finish: 24-Jan-16

--- Sample dates in range (max. 20) ---
 1: 24-Jan-15
end test

test --now 2024/01/15 period "monthly"
--- Period expression tokens ---
TOK_MONTHLY: monthly
END_REACHED: <EOF>

--- Before stabilization ---
duration: 1 month

--- After stabilization ---
   start: 24-Jan-01
duration: 1 month

--- Sample dates in range (max. 20) ---
 1: 24-Jan-01 -- 24-Jan-31
 2: 24-Feb-01 -- 24-Feb-29
 3: 24-Mar-01 -- 24-Mar-31
