; Test min() and max() functions
; Covers session.cc (fn_min, fn_max)

2024/01/15 Small
    Expenses:Food    10 APPLES
    Assets:Inventory

2024/01/20 Large
    Expenses:Food    50 APPLES
    Assets:Inventory

test reg --amount "max(amount, 5 APPLES)" --limit "account =~ /Expenses/"
24-Jan-15 Small                 Expenses:Food             10 APPLES    10 APPLES
24-Jan-20 Large                 Expenses:Food             50 APPLES    60 APPLES
end test
