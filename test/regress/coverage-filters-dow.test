; Coverage test for filters.cc day_of_week_posts
; Tests the --dow option which groups transactions by day of week.
; The day_of_week_posts handler collects posts into 7 buckets
; and reports subtotals for each day.

2024/01/15 Monday Purchase
    Expenses:Food             $50.00
    Assets:Cash

2024/01/16 Tuesday Purchase
    Expenses:Food             $30.00
    Assets:Cash

2024/01/22 Monday Again
    Expenses:Food             $40.00
    Assets:Cash

test reg --dow
24-Jan-15 Mondays               Assets:Cash                 $-90.00      $-90.00
                                Expenses:Food                $90.00            0
24-Jan-16 Tuesdays              Assets:Cash                 $-30.00      $-30.00
                                Expenses:Food                $30.00            0
end test
