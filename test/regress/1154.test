; Regression test for issue #1154: Pivot has confusing filtering properties
; https://github.com/ledger/ledger/issues/1154
;
; When --pivot is used, command-line account filters now match against the
; pivoted account names rather than the original ones.  This allows
; filtering by pivoted name (e.g., "Project:Alpha") to work as expected.

2024/01/01 Payee A
    ; Project: Alpha
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Payee B
    ; Project: Beta
    Expenses:Other   $20.00
    Assets:Cash

2024/01/03 Payee C
    Expenses:Travel  $30.00
    Assets:Cash

; The full pivoted balance shows all transactions: tagged ones under
; Project:Alpha and Project:Beta, untagged ones at top level.
test bal --pivot Project
             $-30.00  Assets:Cash
              $30.00  Expenses:Travel
                   0  Project
                   0    Alpha
             $-10.00      Assets:Cash
              $10.00      Expenses:Food
                   0    Beta
             $-20.00      Assets:Cash
              $20.00      Expenses:Other
--------------------
                   0
end test

; Filtering by a pivoted account name now works: shows only Alpha entries.
test bal --pivot Project Project:Alpha
                   0  Project:Alpha
             $-10.00    Assets:Cash
              $10.00    Expenses:Food
--------------------
                   0
end test

; Filtering by "Expenses" matches both pivoted and unpivoted account names
; that contain "Expenses".
test bal --pivot Project Expenses
              $30.00  Expenses:Travel
              $30.00  Project
              $10.00    Alpha:Expenses:Food
              $20.00    Beta:Expenses:Other
--------------------
              $60.00
end test

; Register also respects pivoted filtering.
test reg --pivot Project Project:Alpha
24-Jan-01 Payee A               Pro:Alph:Expenses:Food       $10.00       $10.00
24-Jan-01 Payee A               Proj:Alpha:Assets:Cash      $-10.00            0
end test
