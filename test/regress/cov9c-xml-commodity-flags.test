; Coverage: commodity.cc put_commodity function for xml output
; Exercises COMMODITY_STYLE_THOUSANDS flag 'T' in xml output

2024/01/01 Test
    Expenses:Food    $1,234.56
    Assets:Cash

test xml Expenses:Food --no-pager
