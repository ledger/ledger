; Regression test for issue #1985: aux_date can be used in queries
; Tests that aux_date comparisons work in --limit expressions.
; Per issue #1157, aux_date falls back to the actual date when no
; explicit auxiliary date is set.

2020/10/01=2020/10/02 Transaction A
    Expenses:Food    $10.00
    Assets:Checking

2020/10/05=2020/10/08 Transaction B
    Expenses:Food    $20.00
    Assets:Checking

2020/10/10 Transaction C (no aux date)
    Expenses:Food    $30.00
    Assets:Checking

; Filter by aux_date >= date: Transaction C has no aux_date so its actual
; date (2020/10/10) is used for comparison, and it passes the filter.
test reg -l "aux_date >= [2020/10/02]"
20-Oct-01 Transaction A         Expenses:Food                $10.00       $10.00
                                Assets:Checking             $-10.00            0
20-Oct-05 Transaction B         Expenses:Food                $20.00       $20.00
                                Assets:Checking             $-20.00            0
20-Oct-10 Transaction C (no a.. Expenses:Food                $30.00       $30.00
                                Assets:Checking             $-30.00            0
end test

; Filter with aux_date check: Transaction B has aux_date 2020/10/08,
; Transaction C falls back to actual date 2020/10/10, both >= 2020/10/05.
test reg -l "aux_date >= [2020/10/05]"
20-Oct-05 Transaction B         Expenses:Food                $20.00       $20.00
                                Assets:Checking             $-20.00            0
20-Oct-10 Transaction C (no a.. Expenses:Food                $30.00       $30.00
                                Assets:Checking             $-30.00            0
end test

; Use has_aux_date to filter only posts with an explicit auxiliary date
test reg -l "has_aux_date and aux_date >= [2020/10/02]"
20-Oct-01 Transaction A         Expenses:Food                $10.00       $10.00
                                Assets:Checking             $-10.00            0
20-Oct-05 Transaction B         Expenses:Food                $20.00       $20.00
                                Assets:Checking             $-20.00            0
end test
