; Coverage test for textual_xacts.cc lines 45-48
; check_command_has_match warning when no automated transaction matches

= "food" :: /Food/
    (Budgets:Food)             -1

; Disable with a name that doesn't match
= "nonexistent" disable

2024/01/01 Test
    Expenses:Food            $10.00
    Assets:Cash

test bal
             $-10.00  Assets:Cash
             $-10.00  Budgets:Food
              $10.00  Expenses:Food
--------------------
             $-10.00
__ERROR__
Warning: "$FILE", line 8: Automated transaction command 'disable' with mask 'nonexistent' didn't match any automated transaction.
end test
