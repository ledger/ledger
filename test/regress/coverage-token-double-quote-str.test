; Coverage test for token.cc
; Tests parsing double-quoted string in expression that fails amount parse
; and falls through to the string parse path

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --display "payee == \"Test\""
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
