; Test account lookup N and O (lines 496-504 of account.cc)
; Exercise the N (count) and O (total) accessors on accounts

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test2
    Expenses:Food    $20.00
    Assets:Cash

test bal --format "%(N):%(O) %(account)\n" --flat --limit "account =~ /Food/"
2:$30.00 Expenses:Food
end test
