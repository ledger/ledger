# Test case related to issue #2413
# The xact command uses --now (or today) for the year, not the year
# directive.  (#707)

apply year 2020

2020-03-02 Shop
    Expenses:Food                              $5.00
    Account

end apply year

year 2025

2025-03-02 Shop
    Expenses:Food                             $10.00
    Account

test --now 2025/04/01 xact 03-03 Shop 10
2025/03/03 Shop
    Expenses:Food                             $10.00
    Account
end test
