; Coverage test for post.cc lines 145-151
; Tests get_virtual and get_real accessors for postings.
; Virtual postings have the POST_VIRTUAL flag set.
; Real postings do not.

2024/03/01 Test
    Expenses:Food     $10.00
    Assets:Cash      $-10.00
    (Budget:Food)     $5.00

test reg --format "%(virtual) %(real) %(account)\n"
false true Expenses:Food
false true Assets:Cash
true false Budget:Food
end test
