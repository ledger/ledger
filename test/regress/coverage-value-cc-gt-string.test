; Test value.cc: is_greater_than STRING paths
; Also exercises STRING > COMMODITY paths

; STRING > STRING
test eval "\"xyz\" > \"abc\""
1
end test

test eval "\"abc\" > \"xyz\""
0
end test

test eval "\"abc\" > \"abc\""
0
end test

; Multiple string comparisons
test eval "\"banana\" > \"apple\""
1
end test

test eval "\"apple\" > \"banana\""
0
end test
