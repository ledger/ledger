; Coverage tests for value.cc in_place_cast (type conversions)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

; Boolean to integer - exercises
test eval 'to_int(true)'
1
end test

test eval 'to_int(false)'
0
end test

; Boolean to amount - exercises
test eval 'to_amount(true)'
1
end test

test eval 'to_amount(false)'
0
end test

; Boolean to string - exercises
test eval 'to_string(true)'
true
end test

test eval 'to_string(false)'
false
end test

; Integer to string - exercises
test eval 'to_string(42)'
42
end test

; Integer to amount - exercises
test eval 'to_amount(42)'
42
end test

; Amount to integer - exercises
test eval 'to_int($10.00)'
10
end test

; Amount to string - exercises
test eval 'to_string($10.00)'
$10.00
end test

; String to integer - exercises
test eval 'to_int("42")'
42
end test

test eval 'to_int("-5")'
-5
end test

; String to amount - exercises
test eval 'to_amount("$25.00")'
$25.00
end test

; String to date - exercises
test eval 'to_date("2024/01/15")'
2024/01/15
end test

; String to datetime - exercises
test eval 'to_datetime("2024/01/15 08:00:00")'
2024/01/15 08:00:00
end test

; String to mask - exercises
test eval 'to_mask("foo")'
/foo/
end test

; Mask to string - exercises
test eval 'to_string(to_mask("bar"))'
bar
end test

; Date to string - exercises
test eval 'to_string([2024/01/15])'
2024/01/15
end test
