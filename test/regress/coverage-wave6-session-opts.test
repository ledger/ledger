; Coverage tests for session.cc
; Tests: uncovered option lookup branches and function paths
; Covers: -Z price_exp, fn_account NULL_VALUE
;   MAKE_OPT_FUNCTOR, lookup 'l' break

2024/01/01 Test
    Expenses:Food            $10.00
    Assets:Cash

; Test -Z (price_exp) option - covers lookup_option 'Z' branch
test bal -Z 24 Expenses
              $10.00  Expenses:Food
end test

; Test --value-expr option
test bal --value-expr "amount" Expenses
              $10.00  Expenses:Food
end test

; Test --time-colon option
test bal --time-colon Expenses
              $10.00  Expenses:Food
end test

; Test --getquote option - covers session.cc (getquote_ option)
test bal --getquote /dev/null Expenses
              $10.00  Expenses:Food
end test

; Test --hashes option
test bal Expenses --hashes sha512
              $10.00  Expenses:Food
end test
