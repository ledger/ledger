; Coverage for journal.cc: partial alias cycle with progress
; alias Exp=Expenses and alias Expenses=Exp:Food form a cycle,
; but expansion makes progress (Exp:Groceries -> Exp:Food:Groceries)
; so it stops without error.

alias Exp=Expenses
alias Expenses=Exp:Food

2024/01/01 Test
    Exp:Groceries    $10.00
    Assets:Cash

test bal --recursive-aliases
             $-10.00  Assets:Cash
              $10.00  Exp:Food:Groceries
--------------------
                   0
end test
