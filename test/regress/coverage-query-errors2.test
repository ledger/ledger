; Tests for query.cc error paths - AND/OR/paren/metadata errors
; Covers: (metadata equality not followed by term)
;         (expected ')' error)
;         (AND operator not followed by argument)
;         (OR operator not followed by argument)

2024/01/01 Test
    ; MyTag: hello
    Expenses  $10
    Assets

; AND operator not followed by argument
test reg Expenses and  -> 1
__ERROR__
Error: and operator not followed by argument
end test

; OR operator not followed by argument
test reg Expenses or  -> 1
__ERROR__
Error: or operator not followed by argument
end test

; expected ')' error
test reg '(' Expenses  -> 1
__ERROR__
Error: Missing ')'
end test

; metadata equality not followed by term
test reg '%MyTag=&'  -> 1
__ERROR__
Error: Metadata equality operator not followed by term
end test
