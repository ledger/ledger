; Coverage test for commodity.cc
; Tests commodity valid() check which is called during journal validation

commodity $
    note US Dollar
    format $1,000.00
    default

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test bal
             $-10.00  Assets:Cash
              $10.00  Expenses:Food
--------------------
                   0
end test
