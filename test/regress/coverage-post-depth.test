; Coverage test for post.cc line 331-332
; Tests get_account_depth accessor.
; The depth of Expenses:Food:Groceries is 3 (three levels deep).

2024/03/01 Groceries
    Expenses:Food:Groceries     $10.00
    Assets:Cash

test reg --format "%(depth) %(account)\n"
3 Expenses:Food:Groceries
