test reg --limit 'account =~ /Food/'
24-Jan-15 Test                  Expenses:Food                $50.00       $50.00
end test

test reg --format '%(amount > 0 ? "pos" : "neg") %(account)\n'
pos Expenses:Food
neg Assets:Cash
pos Expenses:Gas
neg Assets:Cash
end test
