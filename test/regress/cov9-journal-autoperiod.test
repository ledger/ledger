; Coverage for journal.cc lines 503-509: has_xdata with period xacts

~ Monthly
    Expenses:Rent    $1000.00
    Assets:Cash

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --forecast-while "date < [2024/04/01]" --now=2024/01/15
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
24-Feb-01 Forecast transaction  Expenses:Rent              $1000.00     $1000.00
24-Feb-01 Forecast transaction  Assets:Cash               $-1000.00            0
24-Mar-01 Forecast transaction  Expenses:Rent              $1000.00     $1000.00
24-Mar-01 Forecast transaction  Assets:Cash               $-1000.00            0
end test
