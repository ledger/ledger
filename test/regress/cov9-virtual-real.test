; Coverage test for post.cc get_virtual, get_real:
; Exercise virtual and real posting detection.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash
    (Budget:Food)    $10.00

test reg --format "%(virtual) %(real) %(account) %(amount)\n"
false true Expenses:Food $10.00
false true Assets:Cash $-10.00
true false Budget:Food $10.00
end test
