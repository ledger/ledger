; Test --collapse-if-zero option without --collapse
; Note: without --collapse, collapse_posts filter is not added; this tests
; that --collapse-if-zero alone does not affect register output

2024/01/15 Transfer
    Assets:Checking       $-100.00
    Assets:Savings         $100.00

2024/01/20 Purchase
    Expenses:Food          $50.00
    Assets:Checking       $-50.00

2024/01/25 Groceries
    Expenses:Food          $20.00
    Expenses:Drinks        $10.00
    Assets:Checking       $-30.00

test --collapse-if-zero reg Expenses -> 0
24-Jan-20 Purchase              Expenses:Food                $50.00       $50.00
24-Jan-25 Groceries             Expenses:Food                $20.00       $70.00
                                Expenses:Drinks              $10.00       $80.00
end test
