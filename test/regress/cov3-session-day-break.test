; Test session with day-break option
; Covers session.cc lines 103-104 (day_break handling)

2024/01/15 Test1
    Expenses:Food    $50.00
    Assets:Cash

2024/01/15 Test2
    Expenses:Transport    $30.00
    Assets:Cash

test reg --day-break Expenses
24-Jan-15 Test1                 Expenses:Food                $50.00       $50.00
24-Jan-15 Test2                 Expenses:Transport           $30.00       $80.00
end test
