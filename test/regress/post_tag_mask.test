; Test has_tag() with a regex mask pattern
; The tag is defined at the transaction level (metadata before any posting)

2024/01/01 Test
    ; SomeTag: world
    Expenses:Food    $10.00
    Assets:Cash

test reg --limit "has_tag(/SomeTag/)"
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
