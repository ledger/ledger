; Coverage test for times.cc
; Exercise unexpected token in period parsing (default case)
; An unrecognized word that falls through all keyword checks
; becomes UNKNOWN and triggers unexpected

2024/01/01 Test
    Expenses:Food            $10.00
    Assets:Cash

; "foobar" is not a recognized period token, triggers unexpected()
test reg Expenses --period "foobar" -> 1
__ERROR__
Error: Unexpected date period token 'foobar'
end test
