; Tests for value_date, T function lookups
; Covers report.cc

2024/01/15 Test
    Expenses:Food    $50.00
    Assets:Cash

; Test value_date - covers
test reg --format '%(value_date)\n' --head 1 Expenses
2024/01/15
end test

; Test T function (display_total) - covers
test reg --format '%(T)\n' --head 1 Expenses
$50.00
end test

; Test white function lookup - covers
test reg --format '%(white)\n' --head 1 Expenses
white
end test

; Test yellow function lookup - covers
test reg --format '%(yellow)\n' --head 1 Expenses
yellow
end test
