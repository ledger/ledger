; Tests for report.cc normalize_options uncovered lines and error paths
; Covers: report.cc 77 151-154 159-161 163-170 173-175 620 626

; --- Journal data ---
P 2024/01/01 AAPL $150.00
P 2024/01/15 AAPL $155.00

2024/01/01 Test
    Expenses:Food    10 AAPL
    Expenses:Auto    $50.00
    Assets:Cash

; --- Test 1: --output option (suppress color/pager) ---
; With --output, stdout gets nothing; output goes to file
test reg --output /dev/null Expenses
end test

; --- Test 2: -j amount_data option ---
test reg -j Expenses:Food
2024-01-01 10
end test

; --- Test 3: -J total_data option ---
test reg -J Expenses:Auto
2024-01-01 50
end test

; --- Test 4: --immediate -V ---
test reg --immediate -V Expenses:Food
24-Jan-01 Test                  Expenses:Food              $1500.00     $1500.00
end test

; --- Test 5: --percent -V ---
test bal --percent -V Expenses
             100.00%  Expenses
               3.12%    Auto
              96.88%    Food
end test

; --- Test 6: fn_get_at error - index > 0 on non-sequence ---
test reg --format "%(get_at(amount, 1))\n" Expenses:Food
end test

; --- Test 7: --meta option with width ---
test reg --meta "nonexistent:15" Expenses:Auto
               24-Jan-01 Test             Expenses:Auto        $50.00     $50.00
end test
