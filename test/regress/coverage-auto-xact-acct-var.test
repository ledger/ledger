; Coverage test for xact.cc lines 1092-1103
; Tests auto-xact account name $variable substitution.
; The $account variable in the auto-xact's posting account name is
; replaced with the full name of the matching account at runtime.

= Expenses
    Liabilities:Tax:$account  (amount * 0.10)
    Assets:Tax               (-amount * 0.10)

2024/03/01 Test
    Expenses:Food     $100.00
    Assets:Checking

test reg --generated
24-Mar-01 Test                  Expenses:Food               $100.00      $100.00
                                Assets:Checking            $-100.00            0
                                Liab:Tax:Expenses:Food       $10.00       $10.00
                                Assets:Tax                  $-10.00            0
end test
