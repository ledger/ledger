; Coverage tests for --average (-A) combined with various options.
;
; The journal contains transactions spanning Jan-Jul 2024 across three
; Expense sub-accounts (Food, Transport, Utilities) and a separate
; Travel:Food account with mixed $ and EUR for multi-commodity testing.
;
; Each test block documents the combination under test and the expected
; averaging math.

2024/01/01 Grocery Store
    Expenses:Food              $100
    Assets:Checking

2024/01/03 Gas Station
    Expenses:Transport         $50
    Assets:Checking

2024/01/08 Restaurant
    Expenses:Food              $80
    Assets:Checking

2024/01/09 Electric Company
    Expenses:Utilities         $120
    Assets:Checking

2024/01/15 Grocery Store
    Expenses:Food              $90
    Assets:Checking

2024/01/16 Gas Station
    Expenses:Transport         $60
    Assets:Checking

2024/01/22 Restaurant
    Expenses:Food              $70
    Assets:Checking

2024/01/24 Bus Tickets
    Expenses:Transport         $40
    Assets:Checking

2024/02/03 Grocery Store
    Expenses:Food              $110
    Assets:Checking

2024/02/10 Gas Station
    Expenses:Transport         $55
    Assets:Checking

2024/02/17 Restaurant
    Expenses:Food              $75
    Assets:Checking

2024/03/01 Grocery Store
    Expenses:Food              $95
    Assets:Checking

2024/03/15 Electric Company
    Expenses:Utilities         $130
    Assets:Checking

2024/03/20 Gas Station
    Expenses:Transport         $60
    Assets:Checking

2024/04/05 Grocery Store
    Expenses:Food              $105
    Assets:Checking

2024/04/15 Restaurant
    Expenses:Food              $85
    Assets:Checking

2024/04/25 Gas Station
    Expenses:Transport         $45
    Assets:Checking

2024/05/01 Grocery Store
    Expenses:Food              $250
    Assets:Checking

2024/05/15 Electric Company
    Expenses:Utilities         $110
    Assets:Checking

2024/05/28 Gas Station
    Expenses:Transport         $65
    Assets:Checking

2024/06/10 Grocery Store
    Expenses:Food              $120
    Assets:Checking

2024/06/20 Restaurant
    Expenses:Food              $90
    Assets:Checking

2024/06/30 Gas Station
    Expenses:Transport         $55
    Assets:Checking

2024/07/05 Grocery Store
    Expenses:Food              $115
    Assets:Checking

2024/07/15 Electric Company
    Expenses:Utilities         $125
    Assets:Checking

2024/07/25 Gas Station
    Expenses:Transport         $50
    Assets:Checking

; Multi-commodity data (Travel hierarchy, separate from Expenses)
2024/01/15 German Deli
    Travel:Food                50 EUR
    Assets:Euro

2024/01/20 American Diner
    Travel:Food                $100
    Assets:Checking

2024/02/10 European Market
    Travel:Food                30 EUR
    Assets:Euro

2024/02/14 Local Cafe
    Travel:Food                $80
    Assets:Checking

2024/03/05 German Bakery
    Travel:Food                40 EUR
    Assets:Euro

2024/03/18 Street Vendor
    Travel:Food                $120
    Assets:Checking

; ---------------------------------------------------------------------------
; Test 1: Weekly average register (-W -A)
;
; 4 weeks of January, multiple accounts per week.
; Per-account running average: e.g. Food wk1=$100, wk2=$80 avg=$90,
; wk3=$90 stays $90, wk4=$70 => (100+80+90+70)/4=$85.
; Transport wk1=$50, wk3=$60 avg=(50+60)/2+gaps, wk4=$40 avg=$38.
; Utilities appears only in wk2: $120, then avg diminishes with count.

test -W -A --columns 80 --begin 2024/01/01 --end 2024/02/01 reg Expenses
23-Dec-31 - 24-Jan-06           Expenses:Food                  $100         $100
                                Expenses:Transport              $50          $50
24-Jan-07 - 24-Jan-13           Expenses:Food                   $80          $90
                                Expenses:Utilities             $120          $60
24-Jan-14 - 24-Jan-20           Expenses:Food                   $90          $90
                                Expenses:Transport              $60          $37
24-Jan-21 - 24-Jan-27           Expenses:Food                   $70          $85
                                Expenses:Transport              $40          $38
end test

; ---------------------------------------------------------------------------
; Test 2: Quarterly average balance (-Q -A bal)
;
; 3 quarters (Q1: Jan-Mar, Q2: Apr-Jun, Q3: Jul).
; Balance average divides total by number of quarters with postings.
; Food: (620+650+115)/3 = 462 -- but balance average uses visited post
; count, not period count. With 14 Food postings across 3 quarters:
; total=$1385, avg=$1385/14 (rounding) -- shown as per-post average.
; The balance report shows the average per visited posting.

test -Q -A bal Expenses
                 $90  Expenses
                $107    Food
                 $53    Transport
                $121    Utilities
--------------------
                 $90
end test

; ---------------------------------------------------------------------------
; Test 3: Quarterly average register (--period quarterly -A)
;
; Groups postings into quarterly buckets with date ranges.
; Each quarter's amount is the period total; the running total column
; shows the running average across quarters.
; Q1 Food=$620, Q2 Food=$650, Q3 Food=$115
; Running avg: Q1=$620, Q2=(620+650)/2=$635, Q3=(620+650+115)/3=$462

test --period quarterly -A --columns 80 reg Expenses
24-Jan-01 - 24-Mar-31           Expenses:Food                  $620         $620
                                Expenses:Transport             $265         $265
                                Expenses:Utilities             $250         $250
24-Apr-01 - 24-Jun-30           Expenses:Food                  $650         $635
                                Expenses:Transport             $165         $215
                                Expenses:Utilities             $110         $180
24-Jul-01 - 24-Sep-30           Expenses:Food                  $115         $462
                                Expenses:Transport              $50         $160
                                Expenses:Utilities             $125         $162
end test

; ---------------------------------------------------------------------------
; Test 4: Average with --depth 1 register (-M -A --depth 1)
;
; --depth 1 truncates accounts to top level (Expenses).  This disables
; per-account period averaging (since collapse/depth reduces all sub-
; accounts to a single line per period).  The running total column
; shows the running average of the single "Expenses" line.
; Jan=$610, Feb=$240, Mar=$285, Apr=$235, May=$425, Jun=$265, Jul=$290

test -M -A --depth 1 --columns 80 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses                       $610         $610
24-Feb-01 - 24-Feb-29           Expenses                       $240         $425
24-Mar-01 - 24-Mar-31           Expenses                       $285         $378
24-Apr-01 - 24-Apr-30           Expenses                       $235         $342
24-May-01 - 24-May-31           Expenses                       $425         $359
24-Jun-01 - 24-Jun-30           Expenses                       $265         $343
24-Jul-01 - 24-Jul-31           Expenses                       $290         $336
end test

; ---------------------------------------------------------------------------
; Test 5: Average with --depth 1 balance (-M -A --depth 1 bal)
;
; Balance report with --depth 1 shows only the top-level account.
; Average = total across all months / number of visited postings.
; Total Expenses = $2350 from 29 postings. With --depth 1 and -M -A,
; the balance shows the average per month: $2350 / 7 months ~ $336,
; but the actual value depends on the number of posts visited.

test -M -A --depth 1 bal Expenses
                $131  Expenses
end test

; ---------------------------------------------------------------------------
; Test 6: Average with --related (-M -A --related)
;
; --related shows the counterpart (non-matching) accounts.  When
; filtering Expenses, --related shows Assets:Checking (the other side).
; The amounts are the counterpart totals; averages track Assets.

test -M -A --related --columns 80 reg Expenses
24-Jan-01 - 24-Jan-31           Assets:Checking               $-610        $-610
24-Feb-01 - 24-Feb-29           Assets:Checking               $-240        $-425
24-Mar-01 - 24-Mar-31           Assets:Checking               $-285        $-378
24-Apr-01 - 24-Apr-30           Assets:Checking               $-235        $-342
24-May-01 - 24-May-31           Assets:Checking               $-425        $-359
24-Jun-01 - 24-Jun-30           Assets:Checking               $-265        $-343
24-Jul-01 - 24-Jul-31           Assets:Checking               $-290        $-336
end test

; ---------------------------------------------------------------------------
; Test 7: Average with --invert (-M -A --invert)
;
; --invert negates every amount.  Combined with --average, the running
; average is also negated.  Restricted to Jan-Mar for brevity.
; Jan Food: -$340 (inverted from $340), Transport: -$150, Utilities: -$120.

test -M -A --invert --columns 80 --begin 2024/01/01 --end 2024/04/01 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses:Food                 $-340        $-340
                                Expenses:Transport            $-150        $-150
                                Expenses:Utilities            $-120        $-120
24-Feb-01 - 24-Feb-29           Expenses:Food                 $-185        $-262
                                Expenses:Transport             $-55        $-102
24-Mar-01 - 24-Mar-31           Expenses:Food                  $-95        $-207
                                Expenses:Transport             $-60         $-88
                                Expenses:Utilities            $-130         $-83
end test

; ---------------------------------------------------------------------------
; Test 8: Average with --begin/--end (-M -A partial date range)
;
; Only Feb and Mar data.  The average starts fresh from the first
; included period.
; Feb Food=$185, Transport=$55.  Mar Food=$95, Transport=$60, Util=$130.
; Running avg Food: Feb=$185, Mar=(185+95)/2=$140.
; Running avg Transport: Feb=$55, Mar=(55+60)/2=$58 (rounded).
; Utilities: only Mar, so avg=$130/2=$65 (count=2 due to 2 periods).

test -M -A --begin 2024/02/01 --end 2024/04/01 --columns 80 reg Expenses
24-Feb-01 - 24-Feb-29           Expenses:Food                  $185         $185
                                Expenses:Transport              $55          $55
24-Mar-01 - 24-Mar-31           Expenses:Food                   $95         $140
                                Expenses:Transport              $60          $58
                                Expenses:Utilities             $130          $65
end test

; ---------------------------------------------------------------------------
; Test 9: Average with --limit (-M -A --limit 'amount > 100')
;
; Only postings where the individual posting amount exceeds $100 are
; included.  This filters at the posting level before period grouping.
; Qualifying postings: $120(Util), $110(Food), $130(Util), $105(Food),
; $250(Food), $110(Util), $120(Food), $115(Food), $125(Util).
; Each month's qualifying total and running per-account averages shown.

test -M -A --limit 'amount > 100' --columns 80 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses:Utilities             $120         $120
24-Feb-01 - 24-Feb-29           Expenses:Food                  $110          $55
24-Mar-01 - 24-Mar-31           Expenses:Utilities             $130          $83
24-Apr-01 - 24-Apr-30           Expenses:Food                  $105          $54
24-May-01 - 24-May-31           Expenses:Food                  $250          $93
                                Expenses:Utilities             $110          $72
24-Jun-01 - 24-Jun-30           Expenses:Food                  $120          $98
24-Jul-01 - 24-Jul-31           Expenses:Food                  $115         $100
                                Expenses:Utilities             $125          $69
end test

; ---------------------------------------------------------------------------
; Test 10: Average with explicit --period syntax (--period monthly -A)
;
; Equivalent to -M -A.  Verifies that --period monthly produces the
; same grouped output as the -M shorthand.  Restricted to Jan-Mar.

test --period monthly -A --columns 80 --begin 2024/01/01 --end 2024/04/01 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses:Food                  $340         $340
                                Expenses:Transport             $150         $150
                                Expenses:Utilities             $120         $120
24-Feb-01 - 24-Feb-29           Expenses:Food                  $185         $262
                                Expenses:Transport              $55         $102
24-Mar-01 - 24-Mar-31           Expenses:Food                   $95         $207
                                Expenses:Transport              $60          $88
                                Expenses:Utilities             $130          $83
end test

; ---------------------------------------------------------------------------
; Test 11: Average with multi-commodity (-M -A, $ and EUR)
;
; Travel:Food has both $ and EUR postings.  Each commodity is averaged
; independently.  Jan: $100 + 50 EUR.  Feb: $80 + 30 EUR.  Mar: $120 + 40 EUR.
; $ running avg: Jan=$100, Feb=(100+80)/2=$90, Mar=(100+80+120)/3=$100.
; EUR running avg: Jan=50, Feb=(50+30)/2=40, Mar=(50+30+40)/3=40.

test -M -A --columns 80 reg Travel:Food
24-Jan-01 - 24-Jan-31           Travel:Food                    $100
                                                             50 EUR         $100
                                                                          50 EUR
24-Feb-01 - 24-Feb-29           Travel:Food                     $80
                                                             30 EUR          $90
                                                                          40 EUR
24-Mar-01 - 24-Mar-31           Travel:Food                    $120
                                                             40 EUR         $100
                                                                          40 EUR
end test

; ---------------------------------------------------------------------------
; Test 12: Average with --sort amount (-M -A --sort amount)
;
; --sort amount reorders postings within each period by their period
; amount (ascending).  The running average column still tracks per-
; account.  Compare with Test 10: without sort, Food appears before
; Transport; with sort by amount, the order reverses since Transport
; ($150) < Food ($340) in Jan.

test -M -A --sort amount --columns 80 --begin 2024/01/01 --end 2024/04/01 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses:Utilities             $120         $120
                                Expenses:Transport             $150         $150
                                Expenses:Food                  $340         $340
24-Feb-01 - 24-Feb-29           Expenses:Transport              $55         $102
                                Expenses:Food                  $185         $262
24-Mar-01 - 24-Mar-31           Expenses:Transport              $60          $88
                                Expenses:Food                   $95         $207
                                Expenses:Utilities             $130          $83
end test

; ---------------------------------------------------------------------------
; Test 13: Monthly average deviation register (-M -A --deviation)
;
; --deviation shows (period_amount - running_average) per account.
; In period 1, deviation is always 0 (amount equals average so far).
; Period 2 Food: amount=$185, new_avg=$262, dev=$185-$262=-$78.
; Period 3 Food: amount=$95, new_avg=$207, dev=$95-$207=-$112.
; Utilities appears in periods 1 and 3: dev(1)=0, dev(3)=$130-$83=$47.

test -M -A --deviation --columns 80 --begin 2024/01/01 --end 2024/04/01 reg Expenses
24-Jan-01 - 24-Jan-31           Expenses:Food                  $340            0
                                Expenses:Transport             $150            0
                                Expenses:Utilities             $120            0
24-Feb-01 - 24-Feb-29           Expenses:Food                  $185         $-78
                                Expenses:Transport              $55         $-48
24-Mar-01 - 24-Mar-31           Expenses:Food                   $95        $-112
                                Expenses:Transport              $60         $-28
                                Expenses:Utilities             $130          $47
end test

; ---------------------------------------------------------------------------
; Test 14: Average with --empty showing leading empty periods
;
; --begin 2023/11/01 creates empty periods (Nov, Dec) before any data.
; These empty periods increment the period count, so the average is
; diluted.  Jan Food: total=$340 but count=3 (Nov,Dec,Jan) => avg=$113.
; Feb Food: total=$525, count=4 => avg=$131.
; This tests that empty periods correctly contribute to the divisor.

test -M -A --empty --columns 80 --begin 2023/11/01 --end 2024/04/01 reg Expenses
23-Nov-01 - 23-Nov-30           <None>                            0            0
23-Dec-01 - 23-Dec-31           <None>                            0            0
24-Jan-01 - 24-Jan-31           Expenses:Food                  $340         $113
                                Expenses:Transport             $150          $50
                                Expenses:Utilities             $120          $40
24-Feb-01 - 24-Feb-29           Expenses:Food                  $185         $131
                                Expenses:Transport              $55          $51
24-Mar-01 - 24-Mar-31           Expenses:Food                   $95         $124
                                Expenses:Transport              $60          $53
                                Expenses:Utilities             $130          $50
end test

; ---------------------------------------------------------------------------
; Test 15: Balance average with --flat (-M -A --flat bal)
;
; --flat suppresses the hierarchical display and shows each leaf
; account with its full path.  The average is computed per account
; across visited months.  Expenses:Food has postings in all 7 months,
; Expenses:Transport in all 7, Expenses:Utilities in 4 (Jan,Mar,May,Jul).
; Food total=$1385/7=$198 (rounded).
; Transport total=$480/7~$69 (rounded).
; Utilities total=$485/4=$121.

test -M -A --flat bal Expenses
                $198  Expenses:Food
                 $69  Expenses:Transport
                $121  Expenses:Utilities
--------------------
                $131
end test
