; Test justify, format_datetime, and other functions for report.cc coverage
; Covers fn_justify, fn_format_datetime

2024/01/01 Payee
    Expenses:Food            $10.00
    Assets:Cash

2024/01/15 Payee Two
    Expenses:Gas             $20.00
    Assets:Cash

; Test justify function right-justified
test reg Expenses --format "%(justify(payee, 20, 0, true))\n"
               Payee
           Payee Two
end test

; Test format_datetime function
test reg Expenses --format "%(format_datetime(now, \"%Y/%m/%d\"))\n" --now 2024/06/01
2024/06/01
2024/06/01
end test
