; Coverage test for times.cc lines 718-727
; Exercise "N months ago" and "N days hence" expressions
; These exercise the TOK_AGO and TOK_HENCE tokens

2020/01/01 Old
    Expenses:Food            $10.00
    Assets:Cash

; "2 months ago" exercises TOK_AGO path (line 718-720)
test reg Expenses --begin "2 months ago"
end test

; "1 year hence" exercises TOK_HENCE path (line 721-723)
test reg Expenses --begin "1 years hence"
end test

; "3 days ago" exercises TOK_DAYS + TOK_AGO
test reg Expenses --begin "3 days ago"
end test

; "2 weeks hence" exercises TOK_WEEKS + TOK_HENCE
test reg Expenses --begin "2 weeks hence"
end test
