; Test get_cost with an explicit cost (cost-present path)
; Targets: post.cc get_cost when has_cost is true

2024/01/15 * Buy Stock
    Assets:Investments         10 AAPL @ $150.00
    Assets:Checking

; cost returns the cost when present
test reg --format "%(cost) %(has_cost)\n" Assets:Investments
$1500 true
end test
