; Coverage test for xact.cc
; Tests the virtual_null_post balancing path in finalize().
; virtual_balance.is_long path when commodity-less amounts
; post_adder(balance.to_amount) for long balance
; Also covers verify continue for unbalanced virtual posting

2024/01/01 Test Virtual Long
    Expenses:Food    $10.00
    Assets:Cash      $-10.00
    [Budget:Savings]    20
    [Budget:Checking]

test bal
             $-10.00  Assets:Cash
                   0  Budget
                 -20    Checking
                  20    Savings
              $10.00  Expenses:Food
--------------------
                   0
end test

; Also test with virtual unbalanced posting (parentheses)
; which triggers continue in verify
test reg '(Budget)'
24-Jan-01 Test Virtual Long     [Budget:Savings]                 20           20
                                [Budget:Checking]               -20            0
end test
