; Coverage for report.cc line 575: top_amount on SEQUENCE type
; When the value is a sequence, top_amount recurses on the first element

= Expenses
    (Budget:Food)    -1

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --amount '(amount, 0)' --format '%(top_amount(display_amount))\n' Expenses:Food
$10.00
end test
