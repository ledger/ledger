; Test account directive note sub-directive (lines 471-472 of textual_directives.cc)
; Exercise the note keyword within an account directive

account Expenses:Food
    note This is a food expense account

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --format "%(account)%(account.note ? \" \" + account.note : \"\")\n"
Expenses:Food This is a food expense account
Assets:Cash
end test
