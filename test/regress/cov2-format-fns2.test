; Test more format expression functions for report.cc coverage
; Covers fn_join, fn_quoted, fn_quoted_rfc, fn_format_date,
; fn_scrub, fn_rounded, fn_unrounded, fn_abs, fn_trim,
; fn_is_seq, display_amount (t), display_total (T)

2024/01/01 Payee
    Expenses:Food            $10.55
    Assets:Cash

; Test join function
test reg Expenses --format "%(join(payee))\n"
Payee
end test

; Test quoted function
test reg Expenses --format "%(quoted(payee))\n"
"Payee"
end test

; Test quoted_rfc function
test reg Expenses --format "%(quoted_rfc(payee))\n"
"Payee"
end test

; Test format_date function
test reg Expenses --format "%(format_date(date, \"%Y-%m-%d\"))\n"
2024-01-01
end test

; Test scrub function
test reg Expenses --format "%(scrub(amount))\n"
$10.55
end test

; Test rounded function
test reg Expenses --format "%(rounded(amount))\n"
$10.55
end test

; Test unrounded function
test reg Expenses --format "%(unrounded(amount))\n"
$10.55
end test

; Test abs function (fn_abs)
test reg Assets --format "%(abs(amount))\n"
$10.55
end test

; Test trim function
test reg Expenses --format "%(trim(\"  hello  \"))\n"
hello
end test

; Test is_seq function
test reg Expenses --format "%(is_seq(amount) ? \"yes\" : \"no\")\n"
no
end test

; Test display_amount function
test reg Expenses --format "%(t)\n"
$10.55
end test

; Test display_total function
test reg Expenses --format "%(T)\n"
$10.55
end test
