; Test that --related includes postings generated by automated transactions.
; Issue #1832: `reg account -r` was silently dropping sibling postings that
; came from automated (= expr) transactions.

= /^Income:Interests/
    Income:Interests      0.2346
    Expenses:Taxes       -0.2346

2019/11/09 Interests
    Assets:Checking    $20
    Income:Interests

; --related on the income account should show Assets:Checking AND
; the automated Expenses:Taxes posting.
test reg income -r
19-Nov-09 Interests             Assets:Checking                 $20          $20
                                Expenses:Taxes                   $5          $25
end test

; --related on Assets:Checking should show both Income:Interests postings
; (original + auto-generated) and Expenses:Taxes (also auto-generated).
test reg Assets:Checking -r
19-Nov-09 Interests             Income:Interests               $-20         $-20
                                Income:Interests                $-5         $-25
                                Expenses:Taxes                   $5         $-20
end test
