; Coverage test for post.cc
; Tests various post field accessor functions:
; - get_payee: payee from post context
; - get_magnitude: magnitude from post context
; - get_amount: returns 0 for null amount
; - get_cost: returns 0 for null amount
; - get_price: returns 0 for null amount
; - get_total: total from post context
; - get_count: count from post context

2024/03/01 Groceries
    Expenses:Food     $10.00
    Assets:Cash

test reg --format "%(payee) %(magnitude) %(amount) %(cost) %(price) %(total) %(count)\n"
Groceries $10.00 $10.00 $10.00 $10.00 $10.00 1
Groceries $10.00 $-10.00 $-10.00 $-10.00 $0.00 2
end test
