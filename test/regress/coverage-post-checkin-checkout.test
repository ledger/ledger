; Coverage test for post.cc
; Tests get_checkin and get_checkout accessors for timeclock postings.
; Timeclock entries (i/o) generate postings with checkin/checkout times.

i 2024/03/01 09:00:00 Projects:Work
o 2024/03/01 17:00:00

test reg --format "%(checkin) %(checkout)\n"
2024/03/01 09:00:00 2024/03/01 17:00:00
end test
