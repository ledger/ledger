; Coverage test for post.cc
; Tests get_account_base (returns leaf account name)
; and get_account_id (returns position within the account's posts).

2024/03/01 Groceries
    Expenses:Food:Groceries     $10.00
    Assets:Cash

test reg --format "%(account_base) %(account_id)\n"
Groceries 1
Cash 1
end test
