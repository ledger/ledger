; Coverage tests for draft.cc - from keyword, unmatched payee, rest keyword
; Targets (unmatched payee), (cost parsing)
; (negative cost check), (@ cost operator), (@@ cost)

2024/01/01 Grocery Store
    Expenses:Food            $50.00
    Assets:Cash

; Test xact with 'from' keyword - triggers
test xact --now 2024/01/10 Grocery '$25' from Assets:Cash
2024/01/10 Grocery Store
    Expenses:Food                             $25.00
    Assets:Cash
end test

; Test xact with unmatched payee - triggers (payee from template)
test xact --now 2024/01/10 "Brand New Payee" Expenses:Food '$10' Assets:Cash
2024/01/10 Brand New Payee
    Expenses:Food                             $10.00
    Assets:Cash
end test

; Test xact with 'rest' keyword - triggers
test xact --now 2024/01/10 Grocery rest '$25'
2024/01/10 Grocery Store
    Expenses:Food                             $25.00
    Assets:Cash
end test
