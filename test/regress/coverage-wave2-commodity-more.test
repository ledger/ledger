; Additional coverage tests for commodity.cc
; Covers: compare_by_commodity with dates
;   compare_by_commodity with tags
;   parse_symbol quoted
;   map_prices, symbol_needs_quotes

; Quoted commodity symbol - covers parse_symbol quoted paths
2024/01/01 Buy Quoted
    Assets:Special          10 "AA BB"
    Assets:Cash

test bal Assets:Special
            10 AA BB  Assets:Special
end test

; Annotated commodities with different dates for compare_by_commodity
2024/01/02 Buy Date1
    Assets:Dated            5 FOO {$10.00} [2024/01/01]
    Assets:Cash

2024/01/03 Buy Date2
    Assets:Dated            3 FOO {$10.00} [2024/02/01]
    Assets:Cash

test bal --flat --lots Assets:Dated
5 FOO {$10.00} [2024/01/01]
3 FOO {$10.00} [2024/02/01]  Assets:Dated
end test

; Annotated commodities with different tags for compare_by_commodity
2024/01/04 Buy Tag1
    Assets:Tagged           4 BAR {$20.00} (alpha)
    Assets:Cash

2024/01/05 Buy Tag2
    Assets:Tagged           6 BAR {$20.00} (beta)
    Assets:Cash

test bal --flat --lots Assets:Tagged
4 BAR {$20.00} (alpha)
6 BAR {$20.00} (beta)  Assets:Tagged
end test

; Test pricesdb - exercises map_prices
P 2024/01/01 FOO $10.00
P 2024/02/01 FOO $12.00

test prices FOO
2024/01/01 FOO            $10.00
2024/02/01 FOO            $12.00
end test
