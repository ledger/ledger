; Regression test for issue #668
; --csv-separator allows specifying a custom field separator for CSV convert

test -f /dev/null --csv-separator tab convert test/regress/668.csv
2024/01/15 * Grocery Store
    Expenses:Unknown                             -50
    Equity:Unknown

2024/01/20 * Gas Station
    Expenses:Unknown                             -30
    Equity:Unknown
end test
