; Coverage test for select.cc
; Test select with csv, xml, json, and emacs style keywords
; Note: all style variants produce identical output; style selection
; does not change the output format in the current implementation

2024/01/01 Test Payee
    Expenses:Food    $10.00
    Assets:Cash

test select date,payee,account,amount from posts style csv
24-Jan-01 Test Payee               Expenses:Food                         $10.00
24-Jan-01 Test Payee               Assets:Cash                          $-10.00
end test

test select date,payee,account,amount from posts style xml
24-Jan-01 Test Payee               Expenses:Food                         $10.00
24-Jan-01 Test Payee               Assets:Cash                          $-10.00
end test

test select date,payee,account,amount from posts style json
24-Jan-01 Test Payee               Expenses:Food                         $10.00
24-Jan-01 Test Payee               Assets:Cash                          $-10.00
end test

test select date,payee,account,amount from posts style emacs
