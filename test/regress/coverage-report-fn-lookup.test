; Coverage for report.cc function lookup switch cases
; Tests various function names to ensure all switch cases are reached

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

; case 'l': lifo_lots
test eval 'lifo_lots($10)'
$10
end test

; case 'n': null
test eval 'null'
end test

; case 'n': now
test eval --now 2024/06/15 'now'
2024/06/15 00:00:00
end test

; case 'o': options
test eval 'options'
<#SCOPE>
end test

; case 'u': unround
test eval 'unround($10.00)'
$10.00
end test

; case 'w': white
test eval 'white'
white
end test

; case 'y': yellow
test eval 'yellow'
yellow
end test
