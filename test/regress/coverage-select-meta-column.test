; Coverage test for select.cc lines 331-342: meta/unknown column handling
; When a column name is not one of the recognized names (date, aux_date,
; payee, account, amount, total), it falls through to the "else" branch
; which uses meta_width for formatting. This exercises:
;   L331-338: meta column formatter generation
;   L340-341: thus_far += " + " for meta column (when not first)
;   L342: thus_far += "(int(meta_width) or 10) + 1"

2024/01/15 Grocery Store
    Expenses:Food    $50.00
    ; My note
    Assets:Checking

; note is not a recognized select column name, triggering the else branch.
; Put note between amount and date to avoid trailing whitespace.
test select amount, note, date from posts
      $50.00  My note   24-Jan-15
     $-50.00            24-Jan-15
end test
