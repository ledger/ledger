; Coverage test for times.cc line 327: operator<< for yearly duration
; Tests the YEARS case in date_duration_t operator<< via the period command

2024/01/15 Test
    Expenses:Food   $10.00
    Assets:Cash

2024/06/15 Test
    Expenses:Food   $20.00
    Assets:Cash

test reg --yearly --now 2024/01/01
24-Jan-01 - 24-Dec-31           Assets:Cash                 $-30.00      $-30.00
                                Expenses:Food                $30.00            0
end test
