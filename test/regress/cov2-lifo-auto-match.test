; Test LIFO auto-matching for xact.cc lines 334-471
; When selling unannotated shares, LIFO should match newest lots first

2024/01/01 Buy Lot 1
    Assets:Broker          10 AAPL {$100.00} [2024/01/01]
    Assets:Cash

2024/02/01 Buy Lot 2
    Assets:Broker           5 AAPL {$150.00} [2024/02/01]
    Assets:Cash

2024/03/01 Sell unannotated (LIFO auto-match)
    Assets:Broker          -8 AAPL @ $200.00
    Income:Gains

; After LIFO auto-matching: sold 5 from Lot 2 (newest) + 3 from Lot 1
; Remaining: 7 from Lot 1 ($100)
test bal Assets:Broker --lot-matching lifo --lot-prices --lot-dates
7 AAPL {$100} [2024/01/01]  Assets:Broker
end test
