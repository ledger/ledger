; Coverage test for times.cc lines 647, 1213
; Exercise peek_token via bare integer in period expressions

2020/01/15 Transaction A
    Expenses:Food    $10.00
    Assets:Cash

2024/06/15 Transaction B
    Expenses:Food    $20.00
    Assets:Cash

test reg --period "2024"
24-Jun-15 Transaction B         Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
end test
