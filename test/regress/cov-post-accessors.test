; Coverage tests for post.cc accessor functions
; Covers (get_payee), (get_amount null), (get_cost null)
; (get_price null), (get_total null), (get_count no xdata)

2024/01/01 My Payee
    Expenses:Food    $10.00
    Assets:Cash

; Test get_payee
test reg --format "%(payee)\n" Expenses
My Payee
end test

; Test get_count when no xdata
test reg --format "%(N)\n" --limit "N == 1" Expenses
1
end test
