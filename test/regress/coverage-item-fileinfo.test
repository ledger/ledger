; Test item.cc: filebase and filepath lookups
; Exercises get_filebase, get_filepath
; Exercises lookup for "filebase", "filepath"
; Also exercises value_date lookup

2024/01/15 Grocery Store
    Expenses:Food    $50.00
    Assets:Checking

test reg --format "%(filebase)\n" Expenses
coverage-item-fileinfo.test
end test

test reg --format "%(filepath)\n" Expenses
$sourcepath/test/regress
end test

test reg --format "%(value_date)|%(payee)\n" Expenses
2024/01/15|Grocery Store
end test
