; Coverage test for report.cc fn_lifo_lots lookup
; Tests lifo_lots with individual amount_t values (identity passthrough);
; does not trigger the balance_t/lifo_lot_prices code path

2024/01/15 Buy
    Assets:Stock    10 AAPL @ $150
    Assets:Cash    $-1500

2024/02/15 Buy More
    Assets:Stock    5 AAPL @ $160
    Assets:Cash    $-800

test reg --format "%(lifo_lots(amount))\n" Assets:Stock
10 AAPL {$150} [2024/01/15]
5 AAPL {$160} [2024/02/15]
end test
