; Coverage test for format.cc
; Tests STRING element with min_width, expression with min_width for
; value.print, and left-aligned expression padding with spaces

2024/01/15 Test Payee
    Expenses:Food   $100.00
    Assets:Cash

; Test STRING element with min_width
test reg --format "%5%%(account)\n"
    %Expenses:Food
    %Assets:Cash
end test

; Test left-justified expression with padding spaces
test reg --format "%-30(account)|\n"
Expenses:Food                 |
Assets:Cash                   |
end test

; Test right-justified expression with value.print
test reg --format "%30(account)\n"
                 Expenses:Food
                   Assets:Cash
end test

; Test max_width truncation on expression
test reg --format "%.5(account)\n"
Exp..
Ass..
end test
