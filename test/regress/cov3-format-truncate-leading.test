; Test leading truncation style
; Covers format.cc lines 499-501 (TRUNCATE_LEADING style)

2024/01/15 Test
    Expenses:Groceries:Fresh:Produce:Organic    $50.00
    Assets:Cash

test reg --no-total --account-width 20 --truncate=leading
24-Jan-15 Test                  ..sh:Produce:Organic       $50.00       $50.00
                                Assets:Cash               $-50.00            0
end test
