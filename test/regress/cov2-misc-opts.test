; Test miscellaneous option handlers for report.cc coverage
; Covers --gain-since, --aux-date, --auto-match, --no-pager, --round

2024/01/01 Payee
    Expenses:Food            $10.00
    Assets:Cash

2024/02/01 Payee Two
    Expenses:Gas             $20.00
    Assets:Cash

; Test --gain-since option
test reg Expenses --gain-since 2024/01/15
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Feb-01 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --aux-date option
test reg Expenses --aux-date
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Feb-01 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --auto-match option
test reg Expenses --auto-match
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Feb-01 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --no-pager option
test bal Expenses --no-pager
              $30.00  Expenses
              $10.00    Food
              $20.00    Gas
--------------------
              $30.00
end test

; Test --round option
test reg Expenses --round
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Feb-01 Payee Two             Expenses:Gas                 $20.00       $30.00
end test
