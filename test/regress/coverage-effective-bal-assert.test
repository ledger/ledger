; Test balance assertion with --effective using aux dates
2024/01/01=2024/01/01 Deposit
    Assets:Checking    $100.00
    Income:Salary

2024/01/02=2024/01/05 Spend
    Expenses:Food    $10.00
    Assets:Checking    $-10.00 = $90.00

test reg --effective
24-Jan-01 Deposit               Assets:Checking             $100.00      $100.00
                                Income:Salary              $-100.00            0
24-Jan-05 Spend                 Expenses:Food                $10.00       $10.00
                                Assets:Checking             $-10.00            0
end test
