; Test more report format functions for report.cc coverage
; Covers percent, roundto, top_amount, amount_expr, total_expr,
; to_sequence

2024/01/01 Payee
    Expenses:Food            $10.50
    Assets:Cash

2024/02/01 Payee Two
    Expenses:Gas             $20.75
    Assets:Cash

; Test percent function
test reg Expenses --format "%(percent(amount, total))\n"
100.00%
66.40%
end test

; Test roundto function
test reg Expenses --format "%(roundto(amount, 1))\n"
$10.50
$20.80
end test

; Test top_amount function
test reg Expenses --format "%(top_amount(amount))\n"
$10.50
$20.75
end test

; Test amount_expr function
test reg Expenses --format "%(amount_expr)\n"
$10.50
$20.75
end test

; Test total_expr function
test reg Expenses --format "%(total_expr)\n"
$10.50
$31.25
end test

; Test to_sequence function
test reg Expenses --format "%(is_seq(to_sequence(amount)) ? \"yes\" : \"no\")\n"
yes
yes
end test

