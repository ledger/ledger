; Coverage test for post.cc
; Test various post getter functions:
; - get_magnitude
; - get_amount null path
; - get_cost paths
; - get_price with annotation and without
; - get_total paths

2024/01/01 Purchase with cost
    Assets:Investment    10 AAPL @ $50.00
    Assets:Cash

2024/01/02 Simple transaction
    Expenses:Food    $10.00
    Assets:Cash

test reg --format '%(price)\n' Assets:Investment
$500.00
end test

test reg --format '%(cost)\n' Expenses
$10.00
end test

test reg --format '%(total)\n' Expenses
$10.00
end test
