; Coverage: session.cc - fn_int, fn_str
; Also fn_min and fn_max

2024/01/01 Test
    Expenses:Food    $10.50
    Assets:Cash

test reg --format "%(int(amount))\n" --columns=80
10
-10
end test

test reg --format "%(str(amount))\n" --columns=80
$10.50
$-10.50
end test

test reg Expenses --format "%(min(amount, 0))\n" --columns=80
0
end test

test reg Expenses --format "%(max(amount, 0))\n" --columns=80
$10.50
end test
