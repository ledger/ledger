; Coverage test for report.cc
; When --output is set and --color is on (but not --force-color),
; color gets turned off.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --output /dev/stdout --color --limit "account =~ /Expenses/"
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
end test
