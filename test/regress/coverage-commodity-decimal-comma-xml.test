; Coverage test for commodity.cc L527: flags += 'D'
; Tests XML output with a decimal comma commodity, which triggers
; the COMMODITY_STYLE_DECIMAL_COMMA flag ('D') in put_commodity.

D 1.000,00 EUR

2024/01/01 Test
    Expenses:Food    10,50 EUR
    Assets:Cash

test xml bal Expenses | sed -E 's/ (id|ref)="[0-9a-f]+"/ \1="XXXX"/g; s/ version="[0-9]+"/ version="VVVVVV"/g'
<?xml version="1.0" encoding="utf-8"?>
<ledger version="VVVVVV">
  <commodities>
