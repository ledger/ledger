; Test item_t::lookup for various symbols
; 'i' -> is_account and id
; 's' -> status/state and seq
; 'v' -> value_date

2024/01/01 * Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --format "%(is_account) %(status) %(seq) %(value_date)\n"
false 1 2 2024/01/01
false 1 3 2024/01/01
end test
