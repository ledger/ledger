; Coverage for filters.cc transfer_details SET_DATE path
; The --date option overrides the transaction date using a date expression

2024/01/15 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --date "[2024/06/01]"
24-Jun-01 Test                  Expenses:Food                $10.00       $10.00
24-Jun-01 Test                  Assets:Cash                 $-10.00            0
end test
