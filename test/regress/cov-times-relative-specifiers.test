; Coverage test for times.cc
; Exercise various relative date specifiers:
; "this year", "last quarter", "this week", "last day"
; These exercise TOK_YEAR, TOK_QUARTER, TOK_WEEK, TOK_DAY paths

2020/01/01 Old
    Expenses:Food            $10.00
    Assets:Cash

2024/06/01 Mid
    Expenses:Food            $20.00
    Assets:Cash

; "this year" exercises TOK_YEAR with adjust=0
test reg Expenses --begin "this year"
end test

; "last quarter" exercises TOK_QUARTER with adjust=-1
test reg Expenses --begin "last quarter"
end test

; "this week" exercises TOK_WEEK with adjust=0
test reg Expenses --begin "this week"
end test

; "last day" exercises TOK_DAY with adjust=-1
test reg Expenses --begin "last day"
end test
