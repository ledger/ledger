; Coverage test for post.cc lines 226-248:
; get_has_cost(), get_cost(), get_price() return values

2024/01/15 With Cost
    Expenses:Food    10 AAPL @ $15.00
    Assets:Cash

2024/01/20 No Cost
    Expenses:Gas     $30.00
    Assets:Cash

test reg --format '%(has_cost) %(cost) %(price)\n'
true $150.00 $150.00
false $-150.00 $-150.00
false $30.00 $30.00
false $-30.00 $-30.00
end test
