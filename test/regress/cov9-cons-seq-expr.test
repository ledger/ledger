; Coverage test for op.cc O_CONS and O_SEQ:
; Exercise sequence expressions via --gain which uses compound expressions.

P 2024/01/01 AAPL $150.00
P 2024/02/01 AAPL $160.00
P 2024/03/01 AAPL $155.00

2024/01/01 Buy Stock
    Assets:Broker    10 AAPL @ $150.00
    Assets:Cash     $-1500.00

test reg Assets:Broker --gain --begin 2024/01/01 --end 2024/04/01
24-Feb-01 Commodities revalued  <Revalued>                  $100.00      $100.00
24-Mar-01 Commodities revalued  <Revalued>                  $-50.00       $50.00
end test
