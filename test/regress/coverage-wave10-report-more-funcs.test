; Tests for is_seq, join, green function lookups
; Covers report.cc

2024/01/15 Test
    Expenses:Food    $50.00
    Assets:Cash

; Test join function lookup - covers
test reg --format '%(join(account))\n'
Expenses:Food
Assets:Cash
end test

; Test is_seq function - covers report.cc fn_is_seq
test reg --format '%(is_seq(amount))\n' --head 1 Expenses
false
end test

; Test green function lookup - covers
test reg --format '%(green)\n' --head 1 Expenses
green
end test

; Test quantity function lookup - covers
test reg --format '%(quantity(amount))\n' --head 1 Expenses
50
end test

; Test roundto function lookup - covers
test reg --format '%(roundto(amount, 0))\n' --head 1 Expenses
$50.00
end test
