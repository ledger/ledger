; Coverage for report.cc remaining color name functions
; black, blink, cyan, magenta, underline, white, yellow
; Also covers lookup (green, white, yellow)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format "%(black) %(blink) %(cyan) %(magenta) %(underline) %(white) %(yellow)\n"
black blink cyan magenta underline white yellow
end test
