; Test show section keyword with a display predicate
; Exercises parse_query_expr show/only/bold section handling

2024/01/01 Grocery Store
    ; Category: food
    Expenses:Food    $25.00
    Assets:Checking

2024/01/02 Gas Station
    Expenses:Gas    $40.00
    Assets:Checking

2024/01/03 Restaurant
    ; Category: food
    Expenses:Food:Dining    $50.00
    Assets:Checking

test reg Food show Expenses -> 0
24-Jan-01 Grocery Store         Expenses:Food                $25.00       $25.00
24-Jan-03 Restaurant            Expenses:Food:Dining         $50.00       $75.00
end test
