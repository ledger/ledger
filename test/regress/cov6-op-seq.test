; Coverage test for op.cc calc_seq (lines 549-571)
; Tests the O_SEQ operator (semicolon) which evaluates multiple expressions
; in sequence, keeping only the last result.

2024/01/01 Groceries
    Expenses:Food              $50.00
    Assets:Cash

2024/01/02 Rent
    Expenses:Rent             $500.00
    Assets:Cash

test reg --display 'x = 1; amount > 0'
24-Jan-01 Groceries             Expenses:Food                $50.00       $50.00
24-Jan-02 Rent                  Expenses:Rent               $500.00      $500.00
end test
