; Coverage tests for draft.cc - basic xact command paths

2024/01/01 Grocery Store
    Expenses:Food            $50.00
    Assets:Cash

2024/01/02 Gas Station
    Expenses:Gas             $30.00
    Assets:Cash

; Test basic xact (draft) with payee match - triggers (has_year check)
test xact --now 2024/01/10 Grocery
2024/01/10 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with date - triggers date parsing
test xact 2024/03/01 Grocery
2024/03/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with 'on' keyword - triggers
test xact --now 2024/01/10 on 2024/06/15 Grocery
2024/06/15 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with 'code' keyword - triggers
test xact --now 2024/01/10 code CHK123 Grocery
2024/01/10 (CHK123) Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with 'note' keyword - triggers
test xact --now 2024/01/10 note "my note" Grocery
2024/01/10 Grocery Store  ;my note
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with 'at' keyword - triggers
test xact --now 2024/01/10 at Grocery
2024/01/10 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test

; Test xact with 'to' account and amount - triggers
test xact --now 2024/01/10 Grocery to Expenses:Food '$25'
2024/01/10 Grocery Store
    Expenses:Food                             $25.00
    Assets:Cash
end test

; Test xact with explicit amount and account - triggers
test xact --now 2024/01/10 Grocery Expenses:Food '$25'
2024/01/10 Grocery Store
    Expenses:Food                             $25.00
    Assets:Cash
end test
