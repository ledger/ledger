; Test more option handlers for report.cc coverage
; Covers actual, dow, related-all, exact, primary-date,
; collapse-if-zero, revalued, no-revalued, date-format,
; count, color, no-color

2024/01/01 Payee
    Expenses:Food            $10.00
    Assets:Cash

2024/01/15 Payee Two
    Expenses:Gas             $20.00
    Assets:Cash

; Test --actual option (OPT_CH(actual))
test reg Expenses --actual
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --dow option (OPT_ALT(dow, days_of_week))
test reg --dow
24-Jan-01 Mondays               Assets:Cash                 $-30.00      $-30.00
                                Expenses:Food                $10.00      $-20.00
                                Expenses:Gas                 $20.00            0
end test

; Test --related-all option
test reg Expenses --related-all
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $20.00
                                Assets:Cash                 $-20.00            0
end test

; Test --exact option
test bal Expenses --exact
              $30.00  Expenses
              $10.00    Food
              $20.00    Gas
--------------------
              $30.00
end test

; Test --primary-date option
test reg Expenses --primary-date
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --collapse-if-zero option
test reg Expenses --collapse-if-zero
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --revalued option
test reg Expenses --revalued
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --no-revalued option
test reg Expenses --no-revalued
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --date-format option
test reg Expenses --date-format "%Y/%m/%d"
2024/01/01 Payee                Expenses:Food                $10.00       $10.00
2024/01/15 Payee Two            Expenses:Gas                 $20.00       $30.00
end test

; Test --count option
test reg Expenses --count
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --color option
test reg Expenses --color
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test

; Test --no-color option
test reg Expenses --no-color
24-Jan-01 Payee                 Expenses:Food                $10.00       $10.00
24-Jan-15 Payee Two             Expenses:Gas                 $20.00       $30.00
end test
