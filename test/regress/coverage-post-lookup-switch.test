; Coverage test for post.cc
; Tests the switch/break paths in post_t::lookup for single-char
; function names N (count), O (total), and R (real).
; These break statements are hit when the function name matches.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/02/01 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --format='%(N) %(O) %(R) %(account)\n'
1 $10.00 true Expenses:Food
2 $0.00 true Assets:Cash
3 $20.00 true Expenses:Food
4 $0.00 true Assets:Cash
end test
