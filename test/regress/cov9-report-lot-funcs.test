; Coverage test for report.cc
; Test averaged_lots(), fifo_lots(), lifo_lots() with non-balance arguments.
; When the argument is a plain amount (not a balance_t), these functions
; return the argument unchanged (the else branch).

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format '%(averaged_lots(amount))\n'
$10.00
end test

test reg Expenses --format '%(fifo_lots(amount))\n'
$10.00
end test

test reg Expenses --format '%(lifo_lots(amount))\n'
$10.00
end test
