; Coverage tests for textual_directives.cc
; Covers: bucket directive, define directive, year directive,
;         @ prefix on directives, payee directive with alias sub-line,
;         payee directive with blank sub-line,
;         tag directive with blank sub-line,
;         account directive with blank sub-line

; Test 'bucket' directive (case 'b' in general_directive, )
bucket Assets:Checking

; Test 'define' directive (case 'd' in general_directive, )
define my_var=100

; Test 'year' directive (case 'y', )
year 2024

; Test '@' prefix on directive
@commodity $
    format $1,000.00

; A payee directive with a blank sub-line
payee Grocery Store
    alias Groceries

payee Restaurant

; A tag directive with a blank sub-line
tag MyTag

; An account directive with a blank sub-line
account Expenses:Food

account Assets:Checking

2024/01/01 Grocery Store
    Expenses:Food            $25.00
    Assets:Checking

test bal
             $-25.00  Assets:Checking
              $25.00  Expenses:Food
--------------------
                   0
end test
