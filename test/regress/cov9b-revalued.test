; Coverage for filters.cc lines 372, 840: changed_value_posts revaluation
; Use --revalued --market with commodity prices to trigger revaluation output

P 2024/01/01 AAPL $150.00
P 2024/02/01 AAPL $180.00

2024/01/01 Buy Stock
    Assets:Brokerage    10 AAPL @ $150.00
    Assets:Cash        $-1500.00

test reg --revalued --market Assets:Brokerage
24-Jan-01 Buy Stock             Assets:Brokerage           $1500.00     $1500.00
24-Feb-01 Commodities revalued  <Revalued>                  $300.00     $1800.00
end test
