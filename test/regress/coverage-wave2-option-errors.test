; Wave 2 coverage tests for option.cc
; Covers: process_arguments error paths

2024/01/01 Test
    Expenses:Food              $25.00
    Assets:Cash

; Test illegal long option - covers (option_error throw)
test reg --nonexistent-option-xyz -> 1
__ERROR__
Error: Illegal option --nonexistent-option-xyz
end test

; Test -- separator stops option processing - covers
test reg -- Expenses
24-Jan-01 Test                  Expenses:Food                $25.00       $25.00
end test

; Test option with = value
test reg --limit="account =~ /Expenses/"
24-Jan-01 Test                  Expenses:Food                $25.00       $25.00
end test
