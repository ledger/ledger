; Test annotation print with value expression
; Covers annotate.cc (value_expr printing in annotation_t::print)

2024/01/15 Buy
    Assets:Stocks    10 AAPL {$150} ((market(amount, date, "AAPL")))
    Assets:Cash

test print --raw
2024/01/15 Buy
    Assets:Stocks    10 AAPL {$150} ((market(amount, date, "AAPL")))
    Assets:Cash
end test
