; Coverage test for item.cc get_comment function (L364-388).
; Tests both short notes (< 15 chars, uses "  ;") and long notes
; (>= 15 chars, uses "\n    ;"), and items without notes.

2024/01/01 Test
    Expenses:Food    $10.00
      ; short
    Assets:Cash
      ; this is a longer note that is more than 15 characters

2024/01/02 Test2
    Expenses:Rent    $500.00
    Assets:Cash

test reg --format "%(comment)|%(account)\n"
  ; short|Expenses:Food

    ; this is a longer note that is more than 15 characters|Assets:Cash
|Expenses:Rent
|Assets:Cash
end test
