; Coverage for times.cc lines 1749, 1752: TOK_YEAR and unexpected token

2023/01/01 Test1
    Expenses:Food    $10.00
    Assets:Cash

2024/01/01 Test2
    Expenses:Gas    $20.00
    Assets:Cash

test reg --yearly
23-Jan-01 - 23-Dec-31           Assets:Cash                 $-10.00      $-10.00
                                Expenses:Food                $10.00            0
24-Jan-01 - 24-Dec-31           Assets:Cash                 $-20.00      $-20.00
                                Expenses:Gas                 $20.00            0
end test
