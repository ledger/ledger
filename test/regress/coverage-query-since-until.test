; Tests for query.cc: since and until keywords
; Covers: (since/until for_string initialization)
;         (consume_next_arg in for clause)

2024/01/01 Jan
    Expenses  $10
    Assets

2024/06/01 Jun
    Expenses  $20
    Assets

; since keyword
test reg since 2024/03/01
24-Jun-01 Jun                   Expenses                        $20          $20
                                Assets                         $-20            0
end test

; until keyword
test reg until 2024/03/01
24-Jan-01 Jan                   Expenses                        $10          $10
                                Assets                         $-10            0
end test
