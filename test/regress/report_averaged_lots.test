2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format "%(averaged_lots(amount))\n"
$10.00
end test

test reg Expenses --format "%(fifo_lots(amount))\n"
$10.00
end test

test reg Expenses --format "%(lifo_lots(amount))\n"
$10.00
end test
