; Coverage for amount.cc lines 173-199:
; Time colon display also works with the "m" (minutes) commodity.
; Fractional minutes are converted to seconds in the display.
; 90m with --time-colon converts to 1:30h (minutes to hours).

2024/01/01 * Work
    (Billable:Client)    90m

2024/01/02 * Work
    (Billable:Client)    45m

test bal --time-colon
               2:15h  Billable:Client
end test
