; Coverage test for filters.cc line 1296: SET_PAYEE in transfer_details
; Tests --payee option which replaces the payee in output with
; the result of an expression evaluation.

2024/01/01 Shop
    ; Category: grocery
    Expenses:Food    $10.00
    Assets:Cash

test reg --payee='tag("Category")'
24-Jan-01 grocery               Expenses:Food                $10.00       $10.00
24-Jan-01 grocery               Assets:Cash                 $-10.00            0
end test
