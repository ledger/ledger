; Tests for query.cc error paths
; Covers: (operator not followed by argument)
;         (expected ')' error)
;         (NOT operator not followed by argument)
;         (AND operator not followed by argument)
;         (OR operator not followed by argument)

2024/01/01 Test
    Expenses  $10
    Assets

; payee operator not followed by argument
test reg @  -> 1
__ERROR__
Error: payee operator not followed by argument
end test

; note operator not followed by argument
test reg =  -> 1
__ERROR__
Error: note operator not followed by argument
end test

; meta operator not followed by argument
test reg %  -> 1
__ERROR__
Error: meta operator not followed by argument
end test

; NOT operator not followed by argument
test reg not  -> 1
__ERROR__
Error: not operator not followed by argument
end test
