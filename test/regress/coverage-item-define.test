; Test computed tag evaluation (MyCustom:: 42 + 1 evaluates to 43)
; Targets: item.cc tag expression evaluation
; Note: the define directive is parsed but my_tag is never invoked

define my_tag(val) = val

2024/01/15 * Store
    ; MyCustom:: 42 + 1
    Expenses:Food              $50.00
    Assets:Checking

test reg --format "%(tag(\"MyCustom\")) %(account)\n" Expenses
43 Expenses:Food
end test
