; Coverage for compare.cc null sort value handling
; Null sort values should be treated as VOID and sort first,
; not crash with an error.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --sort "null"
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
