; Coverage test for amount.cc
; Exercise the period-followed-by-digit path in amount parsing
; When an amount ends with a period followed by a digit in an expression,
; the period is put back

2024/01/01 Test
    Expenses:Food            $10.00
    Assets:Cash

; Evaluate a simple addition expression
test eval "1+2"
3
end test

; Evaluate an addition expression with spaces around the operator
test eval "10 + 5"
15
end test
