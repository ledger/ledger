; Coverage for value.cc lines 1027-1028: date greater_than comparison
; Using --display with date > [date] exercises is_greater_than for DATE type

2024/01/01 Test1
    Expenses:Food    $10.00
    Assets:Cash

2024/01/15 Test2
    Expenses:Rent    $20.00
    Assets:Cash

2024/02/01 Test3
    Expenses:Misc    $5.00
    Assets:Cash

test reg --display "date > [2024/01/10]"
24-Jan-15 Test2                 Expenses:Rent                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
24-Feb-01 Test3                 Expenses:Misc                 $5.00        $5.00
                                Assets:Cash                  $-5.00            0
end test
