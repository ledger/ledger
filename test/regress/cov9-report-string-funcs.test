; Coverage test for report.cc:
; fn_quoted - quote a string escaping embedded quotes
; fn_quoted_rfc - quote using RFC-style double-quote escaping
; fn_join - join multi-line text replacing newlines with \n

2024/01/01 He said "hello"
    ; Line 1
    ; Line 2
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format '%(quoted(payee))\n'
"He said \"hello\""
end test

test reg Expenses --format '%(quoted_rfc(payee))\n'
"He said ""hello"""
end test

test reg Expenses --format '%(join(note))\n'
 Line 1\n Line 2
end test
