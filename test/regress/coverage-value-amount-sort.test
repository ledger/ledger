; Coverage for value.cc: is_greater_than and is_less_than for AMOUNT type
; Sorting by negative amount triggers both comparison functions

2024/01/01 Test1
    Expenses:Food    $5.00
    Assets:Checking

2024/01/02 Test2
    Expenses:Rent    $25.00
    Assets:Checking

2024/01/03 Test3
    Expenses:Misc    $15.00
    Assets:Checking

test reg Expenses --sort "-amount"
24-Jan-02 Test2                 Expenses:Rent                $25.00       $25.00
24-Jan-03 Test3                 Expenses:Misc                $15.00       $40.00
24-Jan-01 Test1                 Expenses:Food                 $5.00       $45.00
end test
