; Regression test for issue #1164: aliases won't work in cli (BZ#1164)
; https://github.com/ledger/ledger/issues/1164
; Tests that account aliases defined in the journal file are properly
; expanded when used as CLI query arguments.

alias Chk = Assets:Checking
alias Savings = Assets:Savings

2024/01/01 Paycheck
    Chk         $1000.00
    Savings      $500.00
    Income:Salary

test bal Chk
            $1000.00  Assets:Checking
end test

test bal Savings
             $500.00  Assets:Savings
end test

test reg Chk
24-Jan-01 Paycheck              Assets:Checking            $1000.00     $1000.00
end test
