; Coverage test for draft.cc
; Draft xact creation iterates through matching postings.
; The forward loop (non-from) includes all postings (including virtual).
; The reverse loop (from) picks the last must_balance() posting.

2024/01/15 Grocery Store
    (Memo:Food)      $100.00
    Expenses:Food    $50.00
    Assets:Cash

2024/01/20 Gas Station
    Expenses:Gas     $30.00
    Assets:Cash

test xact 2024/03/01 "Grocery"
2024/03/01 Grocery Store
    (Memo:Food)                              $100.00
    Expenses:Food                             $50.00
    Assets:Cash
end test

; With "from", the reverse loop picks the last must_balance() posting

test xact 2024/03/01 "Grocery" from "Cash"
2024/03/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test
