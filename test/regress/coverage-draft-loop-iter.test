; Coverage test for draft.cc lines 445-462:
; Draft xact creation iterates through matching postings, using
; must_balance() to skip unbalanced virtual postings.
; The forward loop (non-from, line 454) picks the first real posting;
; the reverse loop (from, line 445) picks the last real posting.

2024/01/15 Grocery Store
    (Memo:Food)      $100.00
    Expenses:Food    $50.00
    Assets:Cash

2024/01/20 Gas Station
    Expenses:Gas     $30.00
    Assets:Cash

test xact 2024/03/01 "Grocery"
2024/03/01 Grocery Store
    (Memo:Food)                              $100.00
    Expenses:Food                             $50.00
    Assets:Cash
end test

; With "from", the reverse loop picks the last must_balance() posting

test xact 2024/03/01 "Grocery" from "Cash"
2024/03/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Cash
end test
