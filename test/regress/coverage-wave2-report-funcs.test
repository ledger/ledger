; Wave 2 coverage tests for report.cc - functions and commands
; Covers: fn_to_boolean, fn_to_int, fn_to_string, fn_to_amount,
;   fn_to_mask, fn_to_sequence, fn_to_balance, fn_to_date,
;   color functions (fn_red, fn_bold, fn_blue, etc.), fn_false, fn_null,
;   echo_command, budget_command, stats paths, pricemap_command

2024/01/01 Test
    Expenses:Food     $10.00
    Assets:Cash

; Test color function red - covers fn_red
test eval "red"
red
end test

; Test color function bold - covers fn_bold
test eval "bold"
bold
end test

; Test color function blue - covers fn_blue
test eval "blue"
blue
end test

; Test color function cyan - covers fn_cyan
test eval "cyan"
cyan
end test

; Test color function green - covers fn_green
test eval "green"
green
end test

; Test color function magenta - covers fn_magenta
test eval "magenta"
magenta
end test

; Test color function white - covers fn_white
test eval "white"
white
end test

; Test color function yellow - covers fn_yellow
test eval "yellow"
yellow
end test

; Test color function black - covers fn_black
test eval "black"
black
end test

; Test blink color function - covers fn_blink
test eval "blink"
blink
end test

; Test underline color function - covers fn_underline
test eval "underline"
underline
end test

; Test to_string conversion - covers fn_to_string
test eval "to_string(123)"
123
end test

; Test to_int conversion - covers fn_to_int
test eval "to_int(\"42\")"
42
end test

; Test to_boolean conversion - covers fn_to_boolean
test eval "to_boolean(1)"
1
end test

; Test to_amount conversion - covers fn_to_amount
test eval 'to_amount("10.00")'
10
end test

; Test to_mask conversion - covers fn_to_mask
test eval "to_mask(\"test\")"
/test/
end test

; Test to_sequence conversion - covers fn_to_sequence
test eval "to_sequence(42)"
(42)
end test

; Test false function - covers fn_false
test eval "false"
0
end test

; Test null function - covers fn_null
test eval "null"
end test
