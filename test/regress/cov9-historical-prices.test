; Coverage test for filters.cc historical_prices_only path:
; Exercise --historical flag with price history.

P 2024/01/01 AAPL $150.00
P 2024/02/01 AAPL $160.00

2024/01/01 Buy Stock
    Assets:Broker    10 AAPL @ $150.00
    Assets:Cash     $-1500.00

test reg Assets:Broker --market
24-Jan-01 Buy Stock             Assets:Broker              $1500.00     $1500.00
24-Feb-01 Commodities revalued  <Revalued>                  $100.00     $1600.00
end test

test reg Assets:Broker --market --historical
24-Jan-01 Buy Stock             Assets:Broker              $1500.00     $1500.00
end test
