; Coverage test for filters.cc lines 966-967:
; Exercise date_format path in subtotal_posts::report_subtotal.
; Using --date-format with a monthly report subtotal.

2024/01/15 Groceries
    Expenses:Food    $50.00
    Assets:Cash

2024/01/25 Restaurant
    Expenses:Food    $30.00
    Assets:Cash

test reg --monthly --date-format "%Y/%m/%d"
2024/01/01 - 2024/01/31         Assets:Cash                 $-80.00      $-80.00
                                Expenses:Food                $80.00            0
end test
