; Test token parsing with bracket date specifier
; Exercise the date parsing in brackets

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/06/15 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --limit "date >= [2024/06/01]"
24-Jun-15 Test2                 Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
end test
