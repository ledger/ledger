; Test times.cc day-of-week relative date parsing with "next"
; Note: --now appears after --end on the command line, so the epoch
; for "next friday" may be the system date rather than 2026/03/03

2026/03/02 Monday tx
    Expenses:Food   $20.00
    Assets:Cash

2026/03/03 Tuesday tx
    Expenses:Food   $30.00
    Assets:Cash

2026/03/15 Sunday tx
    Expenses:Food   $40.00
    Assets:Cash

test reg --end "next friday" --now 2026/03/03
26-Mar-02 Monday tx             Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
26-Mar-03 Tuesday tx            Expenses:Food                $30.00       $30.00
                                Assets:Cash                 $-30.00            0
end test
