; Coverage test for report.cc lines 1140-1144
; pricemap command prints the commodity price map

P 2024/01/01 AAPL $150.00

2024/01/01 Buy stock
    Assets:Brokerage    1 AAPL @ $150.00
    Assets:Cash

test pricemap
graph G {
0[label=""];
1[label="s"];
2[label="%"];
3[label="m"];
4[label="h"];
5[label="$"];
6[label="AAPL"];
6--5 ;
}
end test
