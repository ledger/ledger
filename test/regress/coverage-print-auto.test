; Test print command which outputs only regular transactions
; Note: auto (=) and periodic (~) transactions are defined but absent
; from expected output; print only emits the regular transaction

2024/01/15 * (1001) Grocery Store
    ; Location: Downtown
    Expenses:Food              $50.00
    Assets:Checking

= Expenses:Food
    (Budget:Food)             -1.0

~ Monthly
    Expenses:Rent             $1000.00
    Assets:Checking

test print -> 0
2024/01/15 * (1001) Grocery Store
    ; Location: Downtown
    Expenses:Food                             $50.00
    Assets:Checking
end test
