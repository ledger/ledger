; Coverage test for compare.cc lines 52-55, 80-107:
; compare_items<post_t> sorts postings by expression
; Inverted sort (-amount) exercises O_NEG path at lines 52-55

2024/01/15 Test1
    Expenses:Food    $50.00
    Assets:Cash

2024/01/20 Test2
    Expenses:Gas     $30.00
    Assets:Cash

; Sort ascending by amount

test reg --sort amount
24-Jan-15 Test1                 Assets:Cash                 $-50.00      $-50.00
24-Jan-20 Test2                 Assets:Cash                 $-30.00      $-80.00
                                Expenses:Gas                 $30.00      $-50.00
24-Jan-15 Test1                 Expenses:Food                $50.00            0
end test

; Sort descending by amount (inverted)

test reg --sort -amount
24-Jan-15 Test1                 Expenses:Food                $50.00       $50.00
24-Jan-20 Test2                 Expenses:Gas                 $30.00       $80.00
                                Assets:Cash                 $-30.00       $50.00
24-Jan-15 Test1                 Assets:Cash                 $-50.00            0
end test
