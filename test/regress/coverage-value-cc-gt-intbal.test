; Test value.cc: is_greater_than INTEGER and BALANCE paths
; Exercises INTEGER > INTEGER, BALANCE > INTEGER
; Also BALANCE > BALANCE

; INTEGER > INTEGER: as_long > val.as_long
test eval "10 > 3"
1
end test

test eval "3 > 10"
0
end test

test eval "5 > 5"
0
end test

test eval "0 > -1"
1
end test

test eval -- "-5 > 0"
0
end test

test eval -- "-1 > -5"
1
end test
