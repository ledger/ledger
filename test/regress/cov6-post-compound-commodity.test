; Test commodity() and primary with compound (subtotaled) values
; Covers post.cc (compound commodity), (compound primary)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/02 Test2
    Expenses:Food    $20.00
    Assets:Cash

test reg --subtotal --format '%(commodity(amount)) %(primary)\n' Expenses
$ false
end test
