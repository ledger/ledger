; Test times.cc lines 789-796: day-of-week relative date parsing
; "last wednesday" from --now 2026/03/03 (Tuesday) resolves to 2026/02/25

2026/02/23 Sunday tx
    Expenses:Food   $5.00
    Assets:Cash

2026/02/24 Monday tx
    Expenses:Food   $10.00
    Assets:Cash

2026/03/02 Monday tx
    Expenses:Food   $20.00
    Assets:Cash

2026/03/03 Tuesday tx
    Expenses:Food   $30.00
    Assets:Cash

test reg --now 2026/03/03 --begin "last wednesday"
26-Mar-02 Monday tx             Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
26-Mar-03 Tuesday tx            Expenses:Food                $30.00       $30.00
                                Assets:Cash                 $-30.00            0
end test
