; Test amount floor and ceiling operations
; Covers amount.cc lines 691-699 (in_place_floor)
; and value.cc lines 1816-1835 (value_t::in_place_floor)

2024/01/01 Test
    Expenses:Food    $10.75
    Assets:Cash

test reg --format="%(floor(display_amount))\n" Expenses
$10.00
end test

test reg --format="%(ceiling(display_amount))\n" Expenses
$11.00
end test
