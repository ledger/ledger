; Test get_cost, get_price, get_total, and get_count accessors
; Postings have real amounts; exercises the accessor format output

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --format "%(cost) %(price) %(total) %(count)\n"
$10.00 $10.00 $10.00 1
$-10.00 $-10.00 $0.00 2
end test
