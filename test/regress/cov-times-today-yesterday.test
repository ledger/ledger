; Coverage test for times.cc
; Exercise today/tomorrow/yesterday tokens in period parsing
; Covers handle_simple_period_token

2020/01/01 Old Transaction
    Expenses:Food            $10.00
    Assets:Cash

; "today" - covers TOK_TODAY case
test reg Expenses --begin today
end test

; "yesterday" - covers TOK_YESTERDAY case
test reg Expenses --begin yesterday
end test
