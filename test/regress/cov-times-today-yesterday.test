; Coverage test for times.cc lines 1085-1093, 1242-1245
; Exercise today/tomorrow/yesterday tokens in period parsing
; Covers handle_simple_period_token

2020/01/01 Old Transaction
    Expenses:Food            $10.00
    Assets:Cash

; "today" - covers TOK_TODAY case (line 1085-1086, 1242-1245)
test reg Expenses --begin today
end test

; "yesterday" - covers TOK_YESTERDAY case (line 1091-1092, 1244-1245)
test reg Expenses --begin yesterday
end test
