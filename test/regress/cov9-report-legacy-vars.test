; Coverage test for report.cc
; Test legacy single-letter value expression variables that are no longer
; supported. These old 2.x variables throw errors with helpful messages.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg Expenses --format '%(i)\n' -> 1
__ERROR__
While handling posting from "$FILE", line 6:
>     Expenses:Food    $10.00
Error: The i value expression variable is no longer supported
end test

test reg Expenses --format '%(V)\n' -> 1
__ERROR__
While handling posting from "$FILE", line 6:
>     Expenses:Food    $10.00
Error: The V and v value expression variables are no longer supported
end test

test reg Expenses --format '%(G)\n' -> 1
__ERROR__
While handling posting from "$FILE", line 6:
>     Expenses:Food    $10.00
Error: The G and g value expression variables are no longer supported
end test
