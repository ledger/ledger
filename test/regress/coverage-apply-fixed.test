; Coverage test for textual_directives.cc
; apply fixed / apply rate directive

commodity $
commodity EUR

apply fixed EUR $1.10

2024/01/01 Test
    Expenses:Travel        EUR 100.00
    Assets:Cash

end apply fixed

test bal --exchange $
            $-110.00  Assets:Cash
             $110.00  Expenses:Travel
--------------------
                   0
end test
