; Test times.cc lines 835-840: "this day" / "last day" in determine_when

2026/03/02 Yesterday tx
    Expenses:Food   $20.00
    Assets:Cash

2026/03/03 Today tx
    Expenses:Food   $30.00
    Assets:Cash

test reg --period "this day" --now 2026/03/03
26-Mar-03 Today tx              Expenses:Food                $30.00       $30.00
                                Assets:Cash                 $-30.00            0
end test

test reg --period "last day" --now 2026/03/03
26-Mar-02 Yesterday tx          Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
end test
