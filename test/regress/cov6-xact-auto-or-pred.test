; Coverage test for xact.cc
; Tests auto transaction matching with an 'or' predicate.
; The quick matcher handles OR predicates for auto transaction matching.

= /Food/ or /Rent/
    (Budget:Living)              -1.0

2024/01/01 Groceries
    Expenses:Food              $50.00
    Assets:Cash

2024/01/02 Rent
    Expenses:Rent             $500.00
    Assets:Cash

2024/01/03 Transport
    Expenses:Transport        $100.00
    Assets:Cash

test bal
            $-650.00  Assets:Cash
            $-550.00  Budget:Living
             $650.00  Expenses
              $50.00    Food
             $500.00    Rent
             $100.00    Transport
--------------------
            $-550.00
end test
