; Coverage test for post.cc
; get_note() combines post note and xact note with newline separator

2024/01/15 Test
    ; xact note
    Expenses:Food    $50.00
    ; post note
    Assets:Cash

; Test 1: Post has own note AND xact has note - combines with newline
; Post also has no note but xact does (only)

test reg --format 'NOTE=[%(note)]\n'
NOTE=[ post note
 xact note]
NOTE=[ xact note]
end test
