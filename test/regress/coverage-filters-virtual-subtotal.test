; Coverage test for filters.cc POST_MUST_BALANCE flag
; Tests handle_value with force_virtual and force_must_balance.
; When subtotal_posts accumulates virtual balanced postings (square brackets),
; it tracks is_virtual and must_balance flags, passing them to handle_value.
; Also covers (amount/compound_value assignment)

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash
    [Budget:Savings]    $5.00
    [Budget:Checking]

2024/01/15 Test2
    Expenses:Food    $20.00
    Assets:Cash
    [Budget:Savings]    $10.00
    [Budget:Checking]

test reg --subtotal
24-Jan-01 - 24-Jan-15           Assets:Cash                 $-30.00      $-30.00
                                [Budget:Checking]           $-15.00      $-45.00
                                [Budget:Savings]             $15.00      $-30.00
                                Expenses:Food                $30.00            0
end test
