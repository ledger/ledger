; Coverage for report.cc:
; fn_percent - computes percentage of one amount relative to another
; fn_commodity - returns the commodity symbol of an amount
; fn_commodity_price - looks up commodity price at a given time
; fn_set_commodity_price - sets a commodity price

P 2024/01/01 AAPL $150.00

2024/01/01 * Buy Stock
    Assets:Brokerage   10 AAPL @ $150.00
    Assets:Cash

; fn_percent
test reg --format '%(percent(amount, $200.00))\n' Assets:Cash
-750.00%
end test

; fn_commodity
test reg --format '%(commodity(amount))\n' Assets:Brokerage
AAPL
end test

; fn_set_commodity_price
test eval 'set_commodity_price(1 AAPL, today, $200)'
end test
