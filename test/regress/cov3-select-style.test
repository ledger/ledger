; Test select with style clause
; Covers select.cc (style keyword handling)
; Note: despite "style csv", output is columnar (not CSV-formatted)

2024/01/15 Grocery Store
    Expenses:Food    $50.00
    Assets:Cash

test select "date, account, amount from posts where account =~ /Expenses/ style csv"
24-Jan-15 Expenses:Food                                                  $50.00
end test
