; Coverage for post.cc line 364: fn_any with second arg (false)
; When any(EXPR, false) is used, the current posting is excluded from testing
; Also exercises op.cc line 588: print_cons for multi-arg function call

2024/01/01 Mixed
    Expenses:Food    $10.00
    Assets:Cash     $-10.00

2024/01/02 AllExpense
    Expenses:Food    $20.00
    Expenses:Rent    $30.00
    Assets:Cash     $-50.00

test reg --limit "any(account =~ /Cash/, false)"
24-Jan-01 Mixed                 Expenses:Food                $10.00       $10.00
24-Jan-02 AllExpense            Expenses:Food                $20.00       $30.00
                                Expenses:Rent                $30.00       $60.00
end test
