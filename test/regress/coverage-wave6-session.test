; Coverage tests for session.cc
; Targets: session options, session functions

; Declare accounts and commodities for pedantic/strict mode
account Expenses:Food
account Assets:Cash
commodity $

2024/01/01 Payee
    Expenses:Food    $50.00
    Assets:Cash

; Test --pedantic session option
test reg --pedantic Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --strict session option
test reg --strict Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --permissive session option
test reg --permissive Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --day-break option
test reg --day-break Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --recursive-aliases option
test reg --recursive-aliases Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --no-aliases option
test reg --no-aliases Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --explicit option
test reg --explicit Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test

; Test --check-payees option
test reg --check-payees Expenses
24-Jan-01 Payee                 Expenses:Food                $50.00       $50.00
end test
