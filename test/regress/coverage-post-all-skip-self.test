; Coverage test for post.cc
; Tests fn_all with second argument false to skip the current posting.
; all(expr, false) evaluates expr against all OTHER postings in the
; transaction. For Transfer: both postings see the other is Assets, so
; both return true. For Groceries: Expenses:Food sees Assets:Cash matches,
; but Assets:Cash sees Expenses:Food does NOT match, so it returns false.

2024/03/01 Transfer
    Assets:Savings    $100.00
    Assets:Checking  $-100.00

2024/03/02 Groceries
    Expenses:Food     $10.00
    Assets:Cash

test reg --limit "all(account =~ /Assets/, false)"
24-Mar-01 Transfer              Assets:Savings              $100.00      $100.00
                                Assets:Checking            $-100.00            0
24-Mar-02 Groceries             Expenses:Food                $10.00       $10.00
end test
