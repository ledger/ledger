; Test textual_directives.cc lines 674-678: tag directive with
; assert sub-directive

tag Receipt
    assert value =~ /yes/

2024/01/01 Test
    ; Receipt: yes
    Expenses:Food   $10.00
    Assets:Cash

test bal
             $-10.00  Assets:Cash
              $10.00  Expenses:Food
--------------------
                   0
end test
