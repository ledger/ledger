; Test commodity comparison with same price but different lot dates
; Covers commodity.cc lines 450-467 (lot date comparison in
; compare_by_commodity)

2024/01/01 Buy early
    Assets:Brokerage    10 AAPL {$150.00} [2024/01/01]
    Assets:Cash        $-1500.00

2024/01/02 Buy late
    Assets:Brokerage    5 AAPL {$150.00} [2024/06/15]
    Assets:Cash         $-750.00

test bal --no-total --lots Brokerage
10 AAPL {$150.00} [2024/01/01]
5 AAPL {$150.00} [2024/06/15]  Assets:Brokerage
end test
