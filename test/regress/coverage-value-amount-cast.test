; Test value.cc: amount operations that trigger balance conversion
; Coverage target: value.cc - AMOUNT += INTEGER with commodity
;   AMOUNT -= INTEGER with commodity
;   AMOUNT += AMOUNT different commodity
;   AMOUNT -= AMOUNT different commodity

2024/01/15 Purchase
    Expenses:Food       $100.00
    Assets:Checking

test bal Expenses:Food --flat --no-total --format "%(account) %(amount + 50)\n" -> 0
Expenses:Food 50
$100.00
end test

test bal Expenses:Food --flat --no-total --format "%(account) %(amount - 50)\n" -> 0
Expenses:Food -50
$100.00
end test
