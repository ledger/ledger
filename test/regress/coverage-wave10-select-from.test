; Coverage for select.cc FROM clause variants
; Tests: from xacts, from transactions
;        from posts, from accounts
;        default no-from path

2024/01/01 Grocery Store
    Expenses:Food    $50.00
    Assets:Checking

2024/01/15 Gas Station
    Expenses:Transport    $30.00
    Assets:Checking

; === Test 1: from xacts (print format, ) ===
test select date,payee,amount from xacts
2024/01/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Checking

2024/01/15 Gas Station
    Expenses:Transport                        $30.00
    Assets:Checking
end test

; === Test 2: from transactions (alias, ) ===
test select date,payee,amount from transactions
2024/01/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Checking

2024/01/15 Gas Station
    Expenses:Transport                        $30.00
    Assets:Checking
end test

; === Test 3: from txns (alias, ) ===
test select date,payee,amount from txns
2024/01/01 Grocery Store
    Expenses:Food                             $50.00
    Assets:Checking

2024/01/15 Gas Station
    Expenses:Transport                        $30.00
    Assets:Checking
end test

; === Test 4: default no-from path ===
test select amount
      $50.00
     $-50.00
      $30.00
     $-30.00
end test

; === Test 5: from accounts ===
test select account,total from accounts
Assets:Checking      $-80.00
Expenses       $80.00
Food       $50.00
Transport       $30.00
            0
end test
