; Tests for query.cc: expr token parsing
; Covers: lines 218-221 (TOK_EXPR handling in parse_query_term)
;         line 296 (recursive parse_query_term for TOK_EXPR)

2024/01/01 Income
    Assets:Checking  $100
    Income:Salary

2024/01/15 Groceries
    Expenses:Food  $25
    Assets:Checking

; expr keyword followed by expression argument (lines 218-221, 296)
test reg expr 'amount>0'
24-Jan-01 Income                Assets:Checking                $100         $100
24-Jan-15 Groceries             Expenses:Food                   $25         $125
end test
