; Coverage test for op.cc line 764:
; Exercise printing an expression with =~ (match) operator.
; The --limit expression with =~ triggers O_MATCH printing in error messages.

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test reg --limit "payee =~ /Test/"
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
