; Regression test for issue #816: nested strtok calls in parse_tags
; corrupted the outer tokenization loop.  Multiple colon-delimited tag
; groups on the same comment line must all be recorded, not just the first.

2024/01/01 Test
    ; :alpha:beta: :gamma:delta:
    Expenses:Food    $10.00
    Assets:Cash

test reg --limit 'has_tag("alpha") and has_tag("beta") and has_tag("gamma") and has_tag("delta")'
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test

test reg --limit 'has_tag("gamma")'
24-Jan-01 Test                  Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0
end test
