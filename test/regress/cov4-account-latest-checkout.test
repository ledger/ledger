; Test account lookup latest_checkout
; Exercise the latest_checkout accessor

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

2024/01/15 Test2
    Expenses:Food    $20.00
    Assets:Cash

test bal --format "%(latest_checkout ? \"Y\" : \"N\") %(account)\n" --flat --limit "account =~ /Food/"
N Expenses:Food
end test
