; Coverage tests for token.cc - token parsing paths
; Tests various token types and reserved words

; Reserved word:
test eval '1 and 1'
1
end test

; Reserved word: div
test eval '10 div 5'
2
end test

; Reserved word: else
test eval '1 if true else 0'
1
end test

; Reserved word: false
test eval 'false'
0
end test

; Reserved word: if
test eval '99 if true'
99
end test

; Reserved word: or
test eval '0 or 42'
42
end test

; Reserved word: not
test eval 'not false'
1
end test

; Reserved word: true
test eval 'true'
1
end test

; Double-ampersand &&
test eval '1 && 1'
1
end test

; Double-pipe ||
test eval '0 || 7'
7
end test

; Single ampersand &
test eval '1 & 1'
1
end test

; Single pipe |
test eval '0 | 5'
5
end test

; Parentheses
test eval '(1 + 2)'
3
end test

; Date literal [date]
test eval '[2024/01/01]'
2024/01/01
end test

; Single-quoted string
test eval "'hello'"
hello
end test

; Double-quoted string
test eval '"world"'
world
end test

; Braced amount {amount}
test eval '{$10}'
$10
end test

; Exclamation/not operator
test eval 'not 0'
1
end test

; Not-equal !=
test eval '1 != 2'
1
end test

; Not-match !~
test eval '"hello" !~ /xyz/'
1
end test

; Minus and subtraction
test eval '5 - 3'
2
end test

; Arrow -> in lambda
test eval '(x -> x + 1)(5)'
6
end test

; Plus
test eval '2 + 3'
5
end test

; Star
test eval '3 * 4'
12
end test

; Query and colon
test eval '1 ? 42 : 0'
42
end test

; Regex literal /regex/
test eval '"abc" =~ /abc/'
1
end test

; Match =~
test eval '"test" =~ /te/'
1
end test

; Equal ==
test eval '5 == 5'
1
end test

; Assign =
test eval 'myvar = 42; myvar'
42
end test

; Less-than <
test eval '1 < 2'
1
end test

; Less-equal <=
test eval '3 <= 3'
1
end test

; Greater-than >
test eval '5 > 3'
1
end test

; Greater-equal >=
test eval '5 >= 5'
1
end test

; Comma operator
test eval 'print(1, 2)'
12
1
end test

; Semicolon operator
test eval 'x = 1; x'
1
end test

; Amount parsing in default case
test eval '$100'
$100
end test

test eval '$25.50'
$25.50
end test
