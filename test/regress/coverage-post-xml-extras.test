; Test post_t::has_tag with inherit=true falling through to xact,
; and get_tag returning value from the posting itself
; Targets: post.cc

2024/01/15 Store
    ; TxnTag: abc
    Expenses:Food              $50.00
        ; PostTag: xyz
    Assets:Checking

; The post has PostTag but not TxnTag on itself (it inherits TxnTag)
; This exercises has_tag with inherit=true falling through to xact
test reg --limit "has_tag(\"PostTag\")" --format "%(tag(\"PostTag\")) %(amount)\n"
xyz $50.00
end test
