; Coverage for the 'csv' output command with a default commodity directive
; Note: the 'csv' output command is not implemented in csv.cc (which is the CSV input parser)

commodity $1,000.00

2024/01/01 Test
    Expenses:Food    $10.00
    Assets:Cash

test csv
"2024/01/01","","Test","Expenses:Food","$","10","",""
"2024/01/01","","Test","Assets:Cash","$","-10","",""
end test
