; Regression test for issue #664: The ==~ operator extracts regex
; match text instead of returning a boolean.
; https://github.com/ledger/ledger/issues/664

2024/01/01 Test Payee
    Expenses:Food:Groceries    $10.00
    Assets:Cash

; The ==~ operator with capture groups returns the first captured
; group as a string.
test reg --format '%(account ==~ /(.+):(.+)/)\n'
Expenses:Food
Assets
end test

; The ==~ operator without capture groups returns the entire match
; as a string.
test reg --format '%(account ==~ /.+:.+/)\n'
Expenses:Food:Groceries
Assets:Cash
end test

; The ==~ operator returns false when the pattern does not match.
test reg --format '%(account ==~ /(xyz)/)\n'
false
false
end test

; The =~ operator always returns a boolean, even with capture groups.
test reg --format '%(account =~ /(.+):(.+)/)\n'
true
true
end test

; The ==~ operator works correctly in boolean context (--limit),
; since non-empty strings are truthy.
test reg --limit 'account ==~ /(.+):(.+)/' --format '%(account)\n'
Expenses:Food:Groceries
Assets:Cash
end test
