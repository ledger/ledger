; Regression test for issue #619: Format functions do not work in --group-title-format (BZ#619)
; https://github.com/ledger/ledger/issues/619

2024/01/15 Payee A
    Expenses:Food    $10.00
    Assets:Cash

2024/02/10 Payee B
    Expenses:Food    $20.00
    Assets:Cash

test reg --group-by date --group-title-format '%(format_date(date, "%B %Y"))\n'
January 2024
24-Jan-15 Payee A               Expenses:Food                $10.00       $10.00
                                Assets:Cash                 $-10.00            0

February 2024
24-Feb-10 Payee B               Expenses:Food                $20.00       $20.00
                                Assets:Cash                 $-20.00            0
end test
