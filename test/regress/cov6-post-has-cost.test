; Test has_cost accessor for postings with and without cost
; Covers post.cc lines 227-228 (has_cost true/false)

2024/01/01 Purchase
    Expenses:Food    10 EUR @ $1.10
    Assets:Cash

2024/01/02 Simple
    Expenses:Drink    $5.00
    Assets:Cash

test reg --format '%(has_cost)\n' Expenses
true
false
end test
