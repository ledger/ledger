; Coverage test for post.cc line 72: get_tag with mask_t returning value
; from the posting itself (not inherited from xact)
; Also covers line 170 (get_payee reaching end of function)

2024/01/01 Test Payee
    ; PostTag: hello
    Expenses:Food    $10.00
    Assets:Cash

test reg --format='%(tag(/Post/)) %(payee)\n'
hello Test Payee
hello Test Payee
end test
