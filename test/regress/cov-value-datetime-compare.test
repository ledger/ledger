; Coverage test for value.cc
; Exercise date comparison in is_less_than
; Sorting by date exercises the date comparison operators

2024/01/15 First
    Expenses:Food            $10.00
    Assets:Cash

2024/01/10 Second
    Expenses:Food            $20.00
    Assets:Cash

2024/01/20 Third
    Expenses:Food            $30.00
    Assets:Cash

test reg Expenses --sort date
24-Jan-10 Second                Expenses:Food                $20.00       $20.00
24-Jan-15 First                 Expenses:Food                $10.00       $30.00
24-Jan-20 Third                 Expenses:Food                $30.00       $60.00
end test
