; Test various commands for report.cc coverage
; Covers print, select, echo

2024/01/01 Grocery Store
    Expenses:Food            $10.00
    Assets:Cash

2024/01/02 * Gas Station
    Expenses:Gas             $20.00
    Assets:Cash

; Test print command
test print
2024/01/01 Grocery Store
    Expenses:Food                             $10.00
    Assets:Cash

2024/01/02 * Gas Station
    Expenses:Gas                              $20.00
    Assets:Cash
end test

; Test echo command
test echo "Hello World"
Hello World
end test

; Test select command
test select date, payee, account, amount
24-Jan-01 Grocery Store            Expenses:Food                         $10.00
24-Jan-01 Grocery Store            Assets:Cash                          $-10.00
24-Jan-02 Gas Station              Expenses:Gas                          $20.00
24-Jan-02 Gas Station              Assets:Cash                          $-20.00
end test
