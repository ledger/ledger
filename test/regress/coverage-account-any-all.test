; Coverage test for account.cc
; fn_any returns false when no posting matches the expression
; account_t::lookup returns nullptr for non-FUNCTION kind
; 'h' case break in switch (has_children_to_display)
; 'n' case break in switch (note)

2024/01/01 Test
    ; Note: some info
    Expenses:Food    $10.00
    Assets:Cash

2024/02/01 Test2
    Expenses:Food    $20.00
    Assets:Cash

; Test any() returning true for some accounts, false for others
test bal --limit='any(amount > 0)'
             $-30.00  Assets:Cash
              $30.00  Expenses:Food
--------------------
                   0
end test

; Test any returning false for all (return false)
test bal --limit='any(amount > 9999)'
end test

; Test all returning false (account.cc) - not all posts > 0
test bal --limit='all(amount > 0)'
end test
