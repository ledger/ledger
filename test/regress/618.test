; Regression test for issue #618: --anon with custom format output
; https://github.com/ledger/ledger/issues/618
;
; Verifies that --anon works correctly with a format that outputs only dates
; and amounts. (Account name and payee anonymization are not exercised by
; this format string.)

2024/01/01 Grocery Store
    Expenses:Food    $50.00
    Assets:Checking

2024/02/01 Electric Company
    Expenses:Utilities    $120.00
    Assets:Checking

test reg --anon --format '%(date) %(amount)\n'
2024/01/01 A50.00
2024/01/01 A-50.00
2024/02/01 A120.00
2024/02/01 A-120.00
end test
