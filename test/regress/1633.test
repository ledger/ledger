; Regression test for issue #1633: ledger xml produces duplicate transactions (BZ#561)
; https://github.com/ledger/ledger/issues/1633
;
; When a transaction has multiple postings matching the account filter,
; it should appear only ONCE in XML output, not once per matching posting.

2024/01/01 Shopping
    Expenses:Food      $10.00
    Expenses:Transport  $5.00
    Assets:Cash       -$15.00

test xml Expenses | sed -E 's/ (id|ref)="[0-9a-f]+"/ \1="XXXX"/g; s/ version="[0-9]+"/ version="VVVVVV"/g'
<?xml version="1.0" encoding="utf-8"?>
<ledger version="VVVVVV">
  <commodities>
    <commodity flags="P">
      <symbol>$</symbol>
    </commodity>
  </commodities>
  <accounts>
    <account id="XXXX">
      <name/>
      <fullname/>
      <account-total>
        <amount>
          <commodity flags="P">
            <symbol>$</symbol>
          </commodity>
          <quantity>15</quantity>
        </amount>
      </account-total>
      <account/>
      <account id="XXXX">
        <name>Expenses</name>
        <fullname>Expenses</fullname>
        <account-total>
          <amount>
            <commodity flags="P">
              <symbol>$</symbol>
            </commodity>
            <quantity>15</quantity>
          </amount>
        </account-total>
        <account id="XXXX">
          <name>Food</name>
          <fullname>Expenses:Food</fullname>
          <account-amount>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>10</quantity>
            </amount>
          </account-amount>
          <account-total>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>10</quantity>
            </amount>
          </account-total>
        </account>
        <account id="XXXX">
          <name>Transport</name>
          <fullname>Expenses:Transport</fullname>
          <account-amount>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>5</quantity>
            </amount>
          </account-amount>
          <account-total>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>5</quantity>
            </amount>
          </account-total>
        </account>
      </account>
    </account>
  </accounts>
  <transactions>
    <transaction>
      <date>2024/01/01</date>
      <payee>Shopping</payee>
      <postings>
        <posting>
          <account ref="XXXX">
            <name>Expenses:Food</name>
          </account>
          <post-amount>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>10</quantity>
            </amount>
          </post-amount>
          <total>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>10</quantity>
            </amount>
          </total>
        </posting>
        <posting>
          <account ref="XXXX">
            <name>Expenses:Transport</name>
          </account>
          <post-amount>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>5</quantity>
            </amount>
          </post-amount>
          <total>
            <amount>
              <commodity flags="P">
                <symbol>$</symbol>
              </commodity>
              <quantity>15</quantity>
            </amount>
          </total>
        </posting>
      </postings>
    </transaction>
  </transactions>
</ledger>

end test
