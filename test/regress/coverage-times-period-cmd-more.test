; Test period command with tokens not yet covered in dump/to_string
; Exercises: token_t::dump and token_t::to_string for:
;   TOK_NEXT
;   TOK_LAST
;   TOK_TODAY
;   TOK_TOMORROW
;   TOK_YESTERDAY
;   TOK_AGO
;   TOK_HENCE
;   TOK_IN
;   TOK_BIWEEKLY
;   TOK_BIMONTHLY
;   TOK_QUARTERLY
;   TOK_DASH
;   TOK_A_WDAY
;   TOK_WEEKS

2024/01/15 Payee A
    Expenses:Food    $50.00
    Assets:Checking

test period --now 2024/06/15 "next year"
--- Period expression tokens ---
TOK_NEXT: next
TOK_YEAR: year
END_REACHED: <EOF>

--- Before stabilization ---
   range: in year 2025

--- After stabilization ---
   range: in year 2025
   start: 25-Jan-01
  finish: 26-Jan-01

--- Sample dates in range (max. 20) ---
 1: 25-Jan-01
end test

test period --now 2024/06/15 "last month"
--- Period expression tokens ---
TOK_LAST: last
TOK_MONTH: month
END_REACHED: <EOF>

--- Before stabilization ---
   range: in year 2024 month May

--- After stabilization ---
   range: in year 2024 month May
   start: 24-May-01
  finish: 24-Jun-01

--- Sample dates in range (max. 20) ---
 1: 24-May-01
end test

test period --now 2024/06/15 "today"
--- Period expression tokens ---
TOK_TODAY: today
END_REACHED: <EOF>

--- Before stabilization ---
   range: in year 2024 month Jun day 15

--- After stabilization ---
   range: in year 2024 month Jun day 15
   start: 24-Jun-15
  finish: 24-Jun-16

--- Sample dates in range (max. 20) ---
 1: 24-Jun-15
end test

