; Test --gain, --basis, --historical options for report.cc coverage
; Covers OPT_CH(gain), OPT_CH(basis), OPT_CH(historical)
; Lines 1171, 1155-1156, 1173-1174

P 2024/01/01 AAPL $100.00
P 2024/06/01 AAPL $150.00

2024/01/01 Buy
    Assets:Broker          10 AAPL @ $100.00
    Assets:Cash

2024/06/01 Sell
    Assets:Broker         -10 AAPL @ $150.00
    Assets:Cash

; Test --gain option (OPT_CH(gain))
test reg Assets:Broker --gain
24-Jun-01 Commodities revalued  <Revalued>                  $500.00      $500.00
end test

; Test --basis option (OPT_CH(basis))
test bal Assets:Broker --basis
            $-500.00  Assets:Broker
end test

; Test --historical option (OPT_CH(historical))
test reg Assets:Broker --historical
24-Jan-01 Buy                   Assets:Broker              $1000.00     $1000.00
24-Jun-01 Sell                  Assets:Broker             $-1500.00     $-500.00
end test
