; Wave 2 coverage tests for textual.cc
; Covers: BOM handling, directive parsing
; Y directive, N directive, D directive, C directive

; Year directive - covers
Y 2024

; Default commodity - covers
D $1000.00

; Nomarket directive - covers
N $

; Price conversion - covers
C 1.00 Mb = 1000 Kb

; Price directive - covers
P 01/01 EUR $1.10

; Option in journal - covers
--input-date-format %m/%d

01/01 Opening Balance
    Assets:Checking          $1000.00
    Equity:Opening

01/15 Grocery Store
    Expenses:Food              $25.00
    Assets:Checking

; Test that all directives work correctly
test bal
             $975.00  Assets:Checking
           $-1000.00  Equity:Opening
              $25.00  Expenses:Food
--------------------
                   0
end test
