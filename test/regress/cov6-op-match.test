; Coverage test for op.cc O_MATCH evaluation path (lines 316-321)
; Tests the =~ match operator in expressions.
; This exercises both the calc and print paths for O_MATCH.

2024/01/01 Groceries
    Expenses:Food              $50.00
    Assets:Cash

2024/01/02 Rent
    Expenses:Rent             $500.00
    Assets:Cash

test reg --display 'account =~ /Food/'
24-Jan-01 Groceries             Expenses:Food                $50.00       $50.00
end test
