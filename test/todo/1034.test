; Regression test for issue #1034: Using --group-by=EXPR and --pivot=EXPR together doesn't work (BZ#1034)
; https://github.com/ledger/ledger/issues/1034
;
; When --group-by and --pivot are used together, the output is empty.
; Using either option alone produces correct output, but combining them
; results in no output at all.

2024/01/01 Grocery Store
    ; Category: food
    Expenses:Food    $50.00
    Assets:Cash

2024/02/01 Grocery Store
    ; Category: food
    Expenses:Food    $30.00
    Assets:Cash

2024/01/15 Gas Station
    ; Category: transport
    Expenses:Transport    $40.00
    Assets:Cash

2024/02/10 Gas Station
    ; Category: transport
    Expenses:Transport    $35.00
    Assets:Cash

test bal --pivot Category
                   0  Category
                   0    food
             $-80.00      Assets:Cash
              $80.00      Expenses:Food
                   0    transport
             $-75.00      Assets:Cash
              $75.00      Expenses:Transport
--------------------
                   0
end test

test bal --group-by 'payee'
Gas Station
             $-75.00  Assets:Cash
              $75.00  Expenses:Transport
--------------------
                   0

Grocery Store
             $-80.00  Assets:Cash
              $80.00  Expenses:Food
--------------------
                   0
end test

test bal --group-by 'payee' --pivot Category
end test
