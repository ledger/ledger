llel: true\n  jobs:\n    - name: cmake-checks\n      group:\n        piped: true\n        jobs:\n          - name: configure\n            run: cmake -B build ${cmakeFlags:--DCMAKE_BUILD_TYPE=Debug -DUSE_PYTHON=ON -DUSE_DOXYGEN=ON -DUSE_GPGME=ON -DBUILD_DOCS=ON}\n          - name: build\n            run: cmake --build build --parallel\n          - name: test\n            run: cd build && ctest --output-on-failure || ctest --rerun-failed --output-on-failure\n          - name: doxygen\n            run: cmake --build build --target doc.doxygen\n          - name: manual\n            run: cmake --build build --target doc\n\n    - name: nix-flake-build\n      run: nix build .\n",
