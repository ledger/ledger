            "content": "name: CMake\n\non:\n  push:\n    branches: main\n  pull_request:\n    branches: main\n\nenv:\n  # Customize the CMake build type here (Release, Debug, RelWithDebInfo, etc.)\n  BUILD_TYPE: Debug\n  # Minimum coverage thresholds required. Raise these as coverage improves.\n  # Measured by LLVM instrumentation across all instrumented binaries.\n  # Current measured values: lines ~81%, functions ~85%.\n  # Thresholds are set slightly below measured values to absorb minor\n  # variation between CI (Ubuntu/gcc) and local (Nix/Clang) environments.\n  MIN_LINE_COVERAGE: 80\n  MIN_FUNC_COVERAGE: 84\n\njobs:\n  build:\n    runs-on: ${{ matrix.config.os }}\n    strategy:\n      fail-fast: false\n      matrix:\n        config:\n          - {\n            os: ubuntu-latest,\n            name: Ubuntu,\n            PY_MAJOR: 3,\n            cmake_args: -DUSE_PYTHON=ON -DUSE_GPGME=ON\n          }\n          - {\n            os: macos-latest,\n            name: MacOS,\n            PY_MAJOR: 3,\n            cmake_args: -DUSE_PYTHON=ON -DUSE_GPGME=ON\n          }\n          - {\n            os: ubuntu-latest,\n            name: Ubuntu-Sanitizers,\n            PY_MAJOR: 3,\n            cmake_args: -DUSE_SANITIZERS=ON\n          }\n    steps:\n      - uses: actions/checkout@v6\n        name: Check out repository code\n\n      - if: runner.os == 'Linux'\n        name: Linux dependencies\n        run: |\n          sudo apt-get update -y\n          sudo ./acprep dependencies --python\n\n      - if: runner.os == 'macOS'\n        name: Mac Dependencies\n        run: |\n          # Unlink and re-link to prevent errors when github mac runner images\n          # install python outside of brew, for example:\n          # https://github.com/orgs/Homebrew/discussions/3895\n          # https://github.com/actions/setup-python/issues/577\n          # https://github.com/actions/runner-images/issues/6459\n          # https://github.com/actions/runner-images/issues/6507\n          # https://github.com/actions/runner-images/issues/2322\n          brew list -1 | grep python | while read formula; do brew unlink $formula; brew link --overwrite $formula; done\n\n          brew update || brew update || echo \"brew update failed (non-fatal, using cached tap)\"\n          brew uninstall cmake\n          ./acprep dependencies --python\n\n      - name: Install lefthook\n        run: npm install -g lefthook\n\n      - name: Build and test\n        run: lefthook run cmake-build-and-test\n        env:\n          cmakeFlags: \"-DCMAKE_BUILD_TYPE=${{env.BUILD_TYPE}} ${{matrix.config.cmake_args}} -DPython_FIND_VERSION_MAJOR=${{matrix.config.PY_MAJOR}}\"\n          ASAN_OPTIONS: ${{ contains(matrix.config.cmake_args, 'USE_SANITIZERS') && 'detect_leaks=1:halt_on_error=0:log_path=/tmp/asan_log' || '' }}\n          LSAN_OPTIONS: ${{ contains(matrix.config.cmake_args, 'USE_SANITIZERS') && 'suppressions=../lsan-suppressions.txt:log_path=/tmp/lsan_log' || '' }}\n          UBSAN_OPTIONS: ${{ contains(matrix.config.cmake_args, 'USE_SANITIZERS') && 'print_stacktrace=1:halt_on_error=0:suppressions=../ubsan-suppressions.txt:log_path=/tmp/ubsan_log' || '' }}\n\n      - name: Report sanitizer findings\n        if: contains(matrix.config.cmake_args, 'USE_SANITIZERS') && always()\n        run: |\n          echo \"=== Sanitizer Report ===\"\n          found=0\n          for prefix in asan_log lsan_log ubsan_log; do\n            files=(/tmp/${prefix}.*)\n            [ -f \"${files[0]}\" ] || continue\n            echo \"--- ${prefix}: ${#files[@]} report(s) ---\"\n            # Deduplicate: extract unique error summaries\n            grep -h \"SUMMARY\\|ERROR\\|runtime error\" \"${files[@]}\" 2>/dev/null | sort -u || true\n            echo\n            found=1\n          done\n          if [ \"$found\" -eq 0 ]; then\n            echo \"No sanitizer issues found.\"\n          else\n            echo \"::warning::Sanitizer issues were detected. See above for details.\"\n          fi\n\n  coverage:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v6\n        name: Check out repository code\n\n      - name: Install dependencies\n        run: |\n          sudo apt-get update -y\n          # acprep dependencies brings in build tools, Boost, Python, etc.\n          sudo ./acprep dependencies --python\n          # llvm provides llvm-profdata and llvm-cov; lcov provides genhtml.\n          sudo apt-get install -y clang llvm lcov\n\n      - name: Configure CMake\n        # USE_LLVM_COV uses Clang instrumentation (-fprofile-instr-generate\n        # -fcoverage-mapping) instead of gcov, so it works with Clang on all\n        # platforms. DISABLE_ASSERTS keeps branch coverage clean.\n        run: |\n          cmake -B ${{github.workspace}}/build \\\n            -DCMAKE_BUILD_TYPE=Debug \\\n            -DCMAKE_C_COMPILER=clang \\\n            -DCMAKE_CXX_COMPILER=clang++ \\\n            -DUSE_LLVM_COV=ON \\\n            -DUSE_PYTHON=ON \\\n            -DDISABLE_ASSERTS=ON\n\n      - name: Build\n        run: cmake --build ${{github.workspace}}/build --config Debug\n\n      - name: Run tests and generate coverage report\n        # The 'coverage' target (from RunCoverage.cmake) runs ctest with\n        # LLVM_PROFILE_FILE set, merges profiles, exports to lcov format,\n        # and generates the HTML report – all in one step.\n        working-directory: ${{github.workspace}}/build\n        run: cmake --build . --target coverage\n\n      - name: Check coverage thresholds\n        working-directory: ${{github.workspace}}/build\n        run: |\n          # Parse coverage.info directly to avoid lcov consistency-check errors\n          # that arise when processing LLVM-generated data with older lcov versions.\n          #   LH / LF  = lines hit / lines found (per file, summed across all files)\n          #   FNH / FNF = functions hit / found\n          eval \"$(awk -F: '\n            /^LH:/  { lh += $2 }\n            /^LF:/  { lf += $2 }\n            /^FNH:/ { fnh += $2 }\n            /^FNF:/ { fnf += $2 }\n            END {\n              line_pct = (lf > 0) ? lh * 100.0 / lf : 0\n              func_pct = (fnf > 0) ? fnh * 100.0 / fnf : 0\n              printf \"LINE_COV=%.1f\\nFUNC_COV=%.1f\\n\", line_pct, func_pct\n            }\n          ' coverage.info)\"\n\n          echo \"Line coverage:     ${LINE_COV}%  (minimum: ${{env.MIN_LINE_COVERAGE}}%)\"\n          echo \"Function coverage: ${FUNC_COV}%  (minimum: ${{env.MIN_FUNC_COVERAGE}}%)\"\n\n          FAILED=0\n          if ! awk \"BEGIN{exit (${LINE_COV} >= ${{env.MIN_LINE_COVERAGE}}) ? 0 : 1}\"; then\n            echo \"::error::Line coverage ${LINE_COV}% is below the minimum of ${{env.MIN_LINE_COVERAGE}}%\"\n            FAILED=1\n          fi\n          if ! awk \"BEGIN{exit (${FUNC_COV} >= ${{env.MIN_FUNC_COVERAGE}}) ? 0 : 1}\"; then\n            echo \"::error::Function coverage ${FUNC_COV}% is below the minimum of ${{env.MIN_FUNC_COVERAGE}}%\"\n            FAILED=1\n          fi\n\n          if [ \"$FAILED\" -eq 1 ]; then\n            exit 1\n          fi\n          echo \"Coverage check passed: lines=${LINE_COV}%, functions=${FUNC_COV}%\"\n\n      - uses: actions/upload-artifact@v7\n        with:\n          name: coverage-report\n          path: ${{github.workspace}}/build/coverage_html/\n          retention-days: 30\n          if-no-files-found: error\n\n  doxygen:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v6\n        name: Check out repository code\n\n      - name: Install dependencies\n        run: |\n          sudo apt-get update -y\n          sudo ./acprep dependencies\n          sudo apt-get install -y doxygen graphviz\n\n      - name: Install lefthook\n        run: npm install -g lefthook\n\n      - name: Build Doxygen documentation\n        run: lefthook run cmake-doxygen\n        env:\n          cmakeFlags: \"-DUSE_DOXYGEN=ON\"\n\n      - uses: actions/upload-artifact@v7\n        with:\n        