# Auto-generated by CMake – do not edit.  See cmake/RunCoverage.cmake.in.
set(BINDIR "@CMAKE_BINARY_DIR@")
set(LLVM_PROFDATA "@LLVM_PROFDATA@")
set(LLVM_COV "@LLVM_COV@")
set(GENHTML "@GENHTML@")
set(LEDGER_EXE "@CMAKE_BINARY_DIR@/ledger")
set(CMAKE_CTEST_COMMAND "@CMAKE_CTEST_COMMAND@")
# Additional instrumented binaries that exercise libledger source files.
set(EXTRA_OBJECTS
    -object "@CMAKE_BINARY_DIR@/TextualTests"
    -object "@CMAKE_BINARY_DIR@/UtilTests"
    -object "@CMAKE_BINARY_DIR@/FilterTests"
    -object "@CMAKE_BINARY_DIR@/MathTests"
)

# 1. Delete stale profile data.
file(GLOB OLD_PROFRAW "${BINDIR}/coverage-*.profraw")
foreach(f ${OLD_PROFRAW})
  file(REMOVE "${f}")
endforeach()

# 2. Run the test suite with profiling enabled.
execute_process(
  COMMAND "${CMAKE_COMMAND}" -E env
          "LLVM_PROFILE_FILE=${BINDIR}/coverage-%p.profraw"
          "${CMAKE_CTEST_COMMAND}" --output-on-failure
  WORKING_DIRECTORY "${BINDIR}"
  RESULT_VARIABLE _ctest_result
)
if(NOT _ctest_result EQUAL 0)
  message(WARNING "ctest exited with code ${_ctest_result}; coverage may be incomplete")
endif()

# 3. Merge all profile data files.
file(GLOB PROFRAW_FILES "${BINDIR}/coverage-*.profraw")
if(NOT PROFRAW_FILES)
  message(FATAL_ERROR "No .profraw files found in ${BINDIR}; did the tests run?")
endif()
execute_process(
  COMMAND "${LLVM_PROFDATA}" merge -sparse ${PROFRAW_FILES}
          -o "${BINDIR}/coverage.profdata"
  RESULT_VARIABLE _merge_result
)
if(NOT _merge_result EQUAL 0)
  message(FATAL_ERROR "llvm-profdata merge failed with code ${_merge_result}")
endif()

# 4. Export coverage data in lcov format.
#    Pass all instrumented binaries so libledger source files are included.
execute_process(
  COMMAND "${LLVM_COV}" export
          --format=lcov
          "--instr-profile=${BINDIR}/coverage.profdata"
          "--ignore-filename-regex=(test/|/nix/store/|/boost/)"
          "${LEDGER_EXE}"
          ${EXTRA_OBJECTS}
  OUTPUT_FILE "${BINDIR}/coverage.info"
  RESULT_VARIABLE _export_result
)
if(NOT _export_result EQUAL 0)
  message(FATAL_ERROR "llvm-cov export failed with code ${_export_result}")
endif()

# 5. Generate HTML report.
execute_process(
  COMMAND "${GENHTML}" "${BINDIR}/coverage.info"
          --output-directory "${BINDIR}/coverage_html"
          --ignore-errors inconsistent,unsupported
  RESULT_VARIABLE _genhtml_result
)
if(NOT _genhtml_result EQUAL 0)
  message(FATAL_ERROR "genhtml failed with code ${_genhtml_result}")
endif()

message(STATUS "Coverage report written to: ${BINDIR}/coverage_html/index.html")
