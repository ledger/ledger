---------------------\n; 5) register --quarterly --average\n;    Single quarter → averages equal period totals.\n; ---------------------------------------------------------------\ntest reg --quarterly --average ^Expenses\n25-Jan-01 - 25-Mar-31           Expenses:Food                  $750         $750\n                                Expenses:Utilities             $450         $450\nend test\n\n; ---------------------------------------------------------------\n; 6) register --yearly --average\n;    Single year → averages equal period totals.\n; ---------------------------------------------------------------\ntest reg --yearly --average ^Expenses\n25-Jan-01 - 25-Dec-31           Expenses:Food                  $750         $750\n                                Expenses:Utilities             $450         $450\nend test\n\n; ---------------------------------------------------------------\n; 7) register --monthly --average for income (negative amounts)\n;    Verify averaging works with negative running totals.\n; ---------------------------------------------------------------\ntest reg --monthly --average ^Income\n25-Jan-01 - 25-Jan-31           Income:Salary               $-5,000      $-5,000\n25-Feb-01 - 25-Feb-28           Income:Salary               $-5,000      $-5,000\n25-Mar-01 - 25-Mar-31           Income:Salary               $-5,000      $-5,000\nend test\n\n; ---------------------------------------------------------------\n; 8) balance --monthly --average\n; ---------------------------------------------------------------\ntest bal --monthly --average ^Expenses\n                $100  Expenses\n                $125    Food\n                 $75    Utilities\n--------------------\n                 $50\nend test\n\n; ---------------------------------------------------------------\n; 9) balance --average (no period grouping)\n; ---------------------------------------------------------------\ntest bal --average ^Expenses\n                $200  Expenses\n             