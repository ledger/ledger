put_path, 'w') as f:\n        json.dump(filtered, f, indent=2)\n\n    print(\n        f\"strip_pch_flags: {len(entries)} -> {len(filtered)} entries\",\n        file=sys.stderr,\n    )\n    return 0\n\n\nif __name__ == '__main__':\n    sys.exit(main())\n",
