            "content": "# lefthook.yml\n#\n# Single source of truth for build/test checks. Used both locally\n# (pre-commit) and in GitHub Actions (`lefthook run <hook-name>`).\n#\n# Set $cmakeFlags to control CMake configuration. The Nix dev shell\n# (`nix develop`) sets this automatically; CI overrides it per job.\n#\n# Excluded (long-running):\n#   - Lint: clang-format, clang-tidy, cppcheck  (lint.yml)\n#   - Performance benchmarks                     (perf.yml)\n#\n# Excluded (nightly/manual only):\n#   - Fuzz testing                               (fuzz.yml)\n#\n# Managed separately (CI-specific post-processing):\n#   - Coverage analysis       (cmake.yml: coverage job)\n\n# ---------------------------------------------------------------------------\n# CI hooks — invoke individually with `lefthook run <name>`\n# ---------------------------------------------------------------------------\n\ncmake-build-and-test:\n  piped: true\n  jobs:\n    - name: configure\n      run: cmake -B build ${cmakeFlags:--DCMAKE_BUILD_TYPE=Debug -DUSE_PYTHON=ON -DUSE_GPGME=ON}\n    - name: build\n      run: cmake --build build --parallel\n    - name: test\n      run: cd build && ctest --output-on-failure || ctest --rerun-failed --output-on-failure\n\ncmake-doxygen:\n  piped: true\n  jobs:\n    - name: configure\n      run: cmake -B build ${cmakeFlags:--DCMAKE_BUILD_TYPE=Debug -DUSE_DOXYGEN=ON}\n    - name: build-doxygen\n      run: cmake --build build --target doc.doxygen\n\ncmake-manual:\n  piped: true\n  jobs:\n    - name: configure\n      run: cmake -B build ${cmakeFlags:--DCMAKE_BUILD_TYPE=Debug -DBUILD_DOCS=ON}\n    - name: build-manual\n      run: cmake --build build --target doc\n\nnix-flake-build:\n  jobs:\n    - run: nix build .\n\n# ---------------------------------------------------------------------------\n# Pre-commit — all checks, optimized for local dev (single configure)\n# ---------------------------------------------------------------------------\n\npre-commit:\n  parallel: true\n  jobs:\n    - name: cmake-checks\n      group:\n        piped: true\n        jobs:\n          - name: configure\n            run: cmake -B build ${cmakeFlags:--DCMAKE_BUILD_TYPE=Debug -DUSE_PYTHON=ON -DUSE_DOXYGEN=ON -DUSE_GPGME=ON -DBUILD_DOCS=ON}\n          - name: build\n            run: cmake --build build --parallel\n          - name: test\n            run: cd build && ctest --output-on-failure || ctest --rerun-failed --output-on-failure\n          - name: doxygen\n            run: cmake --build build --target doc.doxygen\n          - name: manual\n            run: cmake --build build --target doc\n\n    - name: nix-flake-build\n      run: nix build .\n",
